@page
@model VoxAngelos.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password — Vox Angelos</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-left">
            <div class="brand">VOX ANGELOS</div>
            <h1 class="login-title">CITIZEN<br />PORTAL</h1>
            <p class="login-sub">SECURE ACCESS FOR AUTHORIZED PERSONNEL</p>
        </div>
        <div class="login-right">
            <div class="login-form-container">
                <h2 class="form-title">Reset Password</h2>
                <p class="form-sub">Enter your email and a new password below.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert-error"></div>
                    <input asp-for="Input.Code" type="hidden" />

                    <!-- Hidden email field — pre-filled from reset link -->
                    <input asp-for="Input.Email" type="hidden" />

                    <!-- Show email as read-only display text -->
                    <div class="form-group">
                        <label>Email Address</label>
                        <p style="color: rgba(200,230,255,0.8); font-family:'Syne Mono',monospace;
                            font-size:0.85rem; margin:0; padding: 8px 0;">
                            @Model.Input?.Email
                        </p>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password">New Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control"
                               placeholder="Enter new password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.ConfirmPassword">Confirm New Password</label>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                               placeholder="Confirm new password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login">RESET PASSWORD →</button>
                </form>
            </div>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
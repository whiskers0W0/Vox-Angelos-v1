@page
@model VoxAngelos.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos | Reset Password</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/resetpassword.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper">
            <div class="row g-0">
                <div class="col-lg-5 panel-left">
                    <div class="glass-inner">
                        <span class="sys-label">Vox Angelos</span>
                        <h1 class="portal-title">Access<br />Reset</h1>
                        <div class="login-subtext">
                            <p class="login-instruction">
                                Secure your account by creating a new, strong password. Ensure your credentials remain confidential.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 panel-right">
                    <section>
                        <span class="eyebrow">Security Protocol</span>
                        <form method="post" autocomplete="off" novalidate>
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger" id="validationSummary"></div>
                            <input asp-for="Input.Code" type="hidden" />
                            <input asp-for="Input.Email" type="hidden" />

                            <div class="mb-4">
                                <label class="form-text-label">Authorized Account</label>
                                <div class="email-display-pill">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                        <circle cx="12" cy="7" r="4"></circle>
                                    </svg>
                                    @Model.Input?.Email
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.Password" class="form-text-label">New Password</label>
                                <div class="pw-wrapper">
                                    <input asp-for="Input.Password" id="resetPassword" class="form-control tech-input" type="password" placeholder="••••••••" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('resetPassword')" tabindex="-1">
                                        <svg id="resetPassword-eye" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.ConfirmPassword" class="form-text-label">Confirm Password</label>
                                <div class="pw-wrapper">
                                    <input asp-for="Input.ConfirmPassword" id="resetConfirmPassword" class="form-control tech-input" type="password" placeholder="••••••••" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('resetConfirmPassword')" tabindex="-1">
                                        <svg id="resetConfirmPassword-eye" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="mb-4 pt-2">
                                <button type="submit" class="cta">Update Credentials</button>
                            </div>
                        </form>
                    </section>

                    <div class="form-footer mt-5 pt-3">
                        <p class="privacy-note">
                            Protected by <strong>RA 10173</strong>. Password changes are logged for security purposes.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
            function togglePw(inputId) {
                const input = document.getElementById(inputId);
                input.type = input.type === 'password' ? 'text' : 'password';
            }
    </script>
</body>
</html>
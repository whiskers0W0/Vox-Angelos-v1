@page
@model VoxAngelos.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check Your Email";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check Your Email — Vox Angelos</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/forgotpasswordconfirmation.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper">
            <div class="row g-0">
                <div class="col-lg-5 panel-left">
                    <div class="glass-inner">
                        <span class="sys-label">Vox Angelos</span>
                        <h1 class="portal-title">Check<br />Inbox</h1>
                        <div class="login-subtext">
                            <p class="login-instruction">
                                A secure recovery link has been dispatched. Please verify your identity through the provided email instructions.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 panel-right">
                    <section>
                        <span class="eyebrow">Request Processed</span>
                        
                        <div class="confirmation-content">
                            <h2 class="portal-header-text">Link Dispatched</h2>
                            <p class="instruction-text">
                                If an account with that email exists, a password reset link has been sent. Please check your inbox and follow the instructions to secure your account.
                            </p>
                        </div>

                        <div class="mb-4 pt-4">
                            <a href="/Identity/Account/Login" class="cta text-decoration-none">
                                Back to Login
                            </a>
                        </div>
                    </section>

                    <div class="form-footer mt-5 pt-3">
                        <p class="privacy-note">
                            Protected by <strong>RA 10173</strong>. Your recovery session is monitored and encrypted.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
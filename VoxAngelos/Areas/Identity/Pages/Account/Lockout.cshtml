@page
@model LockoutModel
@{
    ViewData["Title"] = "Account Locked";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos — Account Locked</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Syne+Mono&family=Barlow:wght@300;400&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/lockout.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>
    <div class="bg-grid"></div>
    <div class="corner c-tl"></div>
    <div class="corner c-tr"></div>
    <div class="corner c-bl"></div>
    <div class="corner c-br"></div>

    <div class="tech-wrapper">
        <div class="row g-0">

            <div class="col-lg-5 panel-left">
                <div class="eyebrow mb-2">Vox Angelos</div>
                <h1 class="title mb-3">Citizen<br />Portal</h1>
                <p class="tagline mb-0">
                    Secure access for<br />
                    <strong>authorized personnel</strong>
                </p>
            </div>

            <div class="col-lg-7 panel-right">
                <div class="eyebrow mb-3">Security Alert</div>

                <span class="lockout-icon">&#128274;</span>

                <h2 style="font-family:'Oswald',sans-serif; font-weight:600; font-size:1.6rem; color:#fff; letter-spacing:0.08em; margin-bottom:0.5rem;">
                    ACCOUNT LOCKED
                </h2>

                <p style="font-family:'Barlow',sans-serif; font-size:0.95rem; color:rgba(200,230,255,0.7); margin-bottom:1rem;">
                    Too many failed login attempts have been detected.<br />
                    Your account has been temporarily locked for security.
                </p>

                <div class="divider"></div>

                @if (Model.MinutesRemaining > 0 || Model.SecondsRemaining > 0)
                {
                    <p class="lockout-detail">TIME REMAINING BEFORE UNLOCK</p>
                    <div class="time-remaining" id="countdown">
                        <span id="minutes">@Model.MinutesRemaining</span><span style="font-size:1rem; opacity:0.6;">m</span>
                        <span id="seconds">@Model.SecondsRemaining.ToString("D2")</span><span style="font-size:1rem; opacity:0.6;">s</span>
                    </div>
                    <p class="lockout-detail">
                        You may try again in approximately
                        <strong style="color:rgba(0,179,230,0.8);" id="minuteText">
                            @if (Model.MinutesRemaining > 0)
                            {
                                @($"{Model.MinutesRemaining} minute{(Model.MinutesRemaining == 1 ? "" : "s")}")
                            }
                            else
                            {
                                @("less than a minute")
                            }
                        </strong>.
                    </p>
                }
                else
                {
                    <p class="lockout-detail" style="color:rgba(72,187,120,0.8);">
                        Your account lockout has expired. You may try logging in again.
                    </p>
                }

                <div class="divider"></div>

                <p class="lockout-detail mb-4">
                    If you believe this is a mistake or need immediate access,<br />
                    please contact your system administrator.
                </p>

                <a asp-page="./Login" class="cta w-100 text-center text-decoration-none d-block">
                    Back to Login
                    <span class="cta-arr ms-2"></span>
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Total seconds remaining from server
        let totalSeconds = (@Model.MinutesRemaining * 60) + @Model.SecondsRemaining;

        const minutesEl = document.getElementById('minutes');
        const secondsEl = document.getElementById('seconds');
        const minuteText = document.getElementById('minuteText');

        const interval = setInterval(() => {
            if (totalSeconds <= 0) {
                clearInterval(interval);
                document.getElementById('countdown').innerHTML =
                    '<span style="color:rgba(72,187,120,0.8); font-size:1rem;">Unlocked — you may try again.</span>';
                minuteText.textContent = 'now';
                return;
            }

            totalSeconds--;

            const m = Math.floor(totalSeconds / 60);
            const s = totalSeconds % 60;

            minutesEl.textContent = m;
            secondsEl.textContent = s.toString().padStart(2, '0');
            minuteText.textContent = m > 0
                ? `${m} minute${m === 1 ? '' : 's'}`
                : 'less than a minute';

        }, 1000);
    </script>
</body>
</html>
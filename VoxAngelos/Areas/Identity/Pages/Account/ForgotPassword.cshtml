@page
@model VoxAngelos.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — Vox Angelos</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/forgotpassword.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper">
            <div class="row g-0">
                <div class="col-lg-5 panel-left">
                    <div class="glass-inner">
                        <span class="sys-label">Vox Angelos</span>
                        <h1 class="portal-title">Account<br />Recovery</h1>
                        <div class="login-subtext">
                            <p class="login-instruction">
                                Access your secure profile recovery. Enter your registered email to receive verification instructions.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 panel-right">
                    <section>
                        <span class="eyebrow">Identity Verification</span>
                        <form method="post" autocomplete="off" novalidate>
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="d-none" id="validationSummary" role="alert"></div>

                            <div class="mb-4">
                                <label asp-for="Input.Email" class="form-text-label">Email Address</label>
                                <input asp-for="Input.Email" class="form-control tech-input"
                                       placeholder="name@example.com" autocomplete="email" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <div class="mb-4 pt-2">
                                <button type="submit" class="cta">Send Reset Link</button>
                            </div>

                            <div class="d-flex justify-content-center align-items-center mt-4">
                                <a href="/Identity/Account/Login" class="tech-link">Back to Login</a>
                            </div>
                        </form>
                    </section>

                    <div class="form-footer mt-5 pt-3">
                        <p class="privacy-note">
                            Protected by <strong>RA 10173</strong>. Your recovery data is handled in accordance with the Data Privacy Act.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
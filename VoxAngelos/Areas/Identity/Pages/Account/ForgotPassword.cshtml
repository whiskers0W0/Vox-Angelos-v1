@page
@model VoxAngelos.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — Vox Angelos</title>
    <link rel="stylesheet" href="~/css/forgotpassword.css" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-left">
            <div class="brand">VOX ANGELOS</div>
            <h1 class="login-title">Citizen<br />Portal</h1>
            <p class="login-sub">Secure access for <strong>authorized personel</strong></p>
        </div>
        <div class="login-right">
            <div class="login-form-container">
                <h2 class="form-title">Forgot Password</h2>
                <p class="form-sub">Enter your registered email address and we'll send you a reset link.</p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert-error"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email">Email Address</label>
                        <input asp-for="Input.Email" class="form-control"
                               placeholder="Enter your email" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login">SEND RESET LINK →</button>

                    <div style="text-align:center; margin-top:16px;">
                        <a href="/Identity/Account/Login" style="color:#aab; font-size:13px;">
                            Back to Login
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
@page
@model VoxAngelos.Areas.Identity.Pages.Account.ResetPasswordConfirmationModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Reset — Vox Angelos</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-left">
            <div class="brand">VOX ANGELOS</div>
            <h1 class="login-title">CITIZEN<br />PORTAL</h1>
            <p class="login-sub">SECURE ACCESS FOR AUTHORIZED PERSONNEL</p>
        </div>
        <div class="login-right">
            <div class="login-form-container">
                <h2 class="form-title">Password Reset Successful</h2>
                <p class="form-sub">
                    Your password has been reset successfully.
                    You can now log in with your new password.
                </p>
                <div style="text-align:center; margin-top:24px;">
                    <a href="/Identity/Account/Login" class="btn-login"
                           style="display:inline-block; text-decoration:none;">
                        GO TO LOGIN →
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
@page
@model VoxAngelos.Areas.Identity.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password Reset Successful";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos | Reset Successful </title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/resetpasswordconfirmation.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper">
            <div class="row g-0">
                <div class="col-lg-5 panel-left">
                    <div class="glass-inner">
                        <span class="sys-label">Vox Angelos</span>
                        <h1 class="portal-title">Update<br />Complete</h1>
                        <div class="login-subtext">
                            <p class="login-instruction">
                                Your security credentials have been successfully updated. You may now proceed to the secure portal.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 panel-right">
                    <section>
                        <span class="eyebrow">Success Confirmed</span>
                        
                        <div class="confirmation-content">
                            <div class="success-icon-wrapper mb-4">
                                <svg viewBox="0 0 100 100" class="svg-icon svg-success">
                                    <circle cx="50" cy="50" r="42" stroke="#38a169" stroke-width="5" fill="none" />
                                    <path d="M30,52 L45,65 L70,35" stroke="#38a169" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                                </svg>
                            </div>
                            <h2 class="portal-header-text">Password Reset</h2>
                            <p class="instruction-text">
                                Your password has been changed successfully. Your account is now secured with your new credentials.
                            </p>
                        </div>

                        <div class="mb-4 pt-4">
                            <a href="/Identity/Account/Login" class="cta text-decoration-none">
                                Go to Login
                            </a>
                        </div>
                    </section>

                    <div class="form-footer mt-5 pt-3">
                        <p class="privacy-note">
                            Protected by <strong>RA 10173</strong>. Security logs have been updated with this session's activity.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
@page
@model VoxAngelos.Areas.Identity.Pages.Account.RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Submitted";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration Submitted | Vox Angelos</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/registerconfirmation.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper confirmation-card">
            <div class="card-content">
                
                <div class="status-icon-container">
                    <svg viewBox="0 0 100 100" class="svg-icon svg-info">
                        <circle cx="50" cy="50" r="42" stroke="#2B45B0" stroke-width="5" fill="none" />
                        <path d="M50,30 L50,55" stroke="#2B45B0" stroke-width="6" stroke-linecap="round" />
                        <circle cx="50" cy="70" r="3" fill="#2B45B0" />
                    </svg>
                </div>

                <span class="sys-label mx-auto mb-3">Vox Angelos</span>
                
                <h1 class="portal-title text-center mb-4">Application<br />Submitted</h1>

                <div class="message-body">
                    <p class="instruction-text">
                        Thank you for registering, <strong class="text-primary-blue">@Model.Email</strong>.
                    </p>

                    <p class="status-alert">
                        Your account is currently <span class="highlight-blue">pending admin approval</span>.
                        This process typically takes 1 to 3 business days.
                    </p>

                    <p class="instruction-text mb-5">
                        You will receive an automated email once your credentials have been verified. Please monitor your inbox and spam folders for further instructions.
                    </p>
                </div>

                <div class="divider-neo"></div>

                <div class="redirect-section">
                    <p class="security-note">Authorized Personnel Tracking Active</p>
                    <p class="countdown-text">
                        Redirecting to login in <span id="countdown" class="count-num">5</span> seconds...
                    </p>

                    <a href="/Identity/Account/Login" class="cta mx-auto text-decoration-none">
                        Go to Login Now
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
            let seconds = 5;
            const timer = setInterval(function () {
                seconds--;
                const el = document.getElementById('countdown');
                if (el) el.textContent = seconds;
                if (seconds <= 0) {
                    clearInterval(timer);
                    window.location.href = '/Identity/Account/Login';
                }
            }, 1000);
    </script>
</body>
</html>
@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos | Register</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div id="loadingModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,30,0.8); backdrop-filter:blur(8px); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:20px;">
        <div style="position:relative; width:80px; height:80px; display:flex; align-items:center; justify-content:center; background:#EAECF5; border-radius:50%; box-shadow: 10px 10px 20px rgba(163, 177, 198, 0.7), -10px -10px 20px rgba(255, 255, 255, 0.9);">
            <div style="width:50px; height:50px; border:4px solid rgba(43, 69, 176, 0.1); border-top-color:#2B45B0; border-radius:50%; animation:spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;"></div>
        </div>
        <p style="font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; font-size:0.7rem; letter-spacing:0.25em; color:#2B45B0; text-transform:uppercase; font-weight:800; text-shadow: 0 0 15px rgba(43, 69, 176, 0.2);">
            Authenticating Data
        </p>
    </div>

    <div id="resultModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,30,0.7); backdrop-filter:blur(4px); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:#EAECF5; border:1px solid rgba(255,255,255,0.7); border-radius:30px; padding:3rem 2rem; max-width:420px; width:92%; text-align:center; box-shadow: 20px 20px 60px rgba(0,0,0,0.4), inset 1px 2px 2px 0 #ffffff70, inset -1px -2px 2px 0 #00000030;">
            <div id="resultIcon" style="display:inline-flex; align-items:center; justify-content:center; width:90px; height:90px; border-radius:50%; background:#EAECF5; box-shadow: inset 6px 6px 12px rgba(163, 177, 198, 0.7), inset -6px -6px 12px rgba(255, 255, 255, 0.9); margin-bottom:1.5rem; font-size:3rem;"></div>
            <h3 id="resultTitle" style="font-family:'Oswald', sans-serif; letter-spacing:0.05em; text-transform:uppercase; color:#2B45B0; margin-bottom:0.75rem; font-size:1.8rem; font-weight:700;"></h3>
            <p id="resultMessage" style="font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; color:#718096; font-size:0.95rem; margin-bottom:2rem; line-height:1.7; font-weight:400; padding:0 10px;"></p>
            <button onclick="closeResultModal()" class="cta" style="width:auto; padding:14px 50px; background:linear-gradient(135deg, #445ec9, #2B45B0); color:white; border:none; border-radius:14px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; box-shadow: inset 1px 2px 2px 0 #ffffff70, 6px 6px 20px rgba(43, 69, 176, 0.3); cursor:pointer;">
                Acknowledge
            </button>
        </div>
    </div>

    <div class="main-viewport d-flex align-items-center justify-content-center w-100">
        <div class="tech-wrapper">
            <div class="row g-0">
                <div class="col-lg-5 panel-left d-none d-lg-flex">
                    <div class="glass-inner w-100">
                        <span class="sys-label">Vox Angelos</span>
                        <h1 class="portal-title">Citizen<br />Registration</h1>
                        <p class="tagline mb-4">
                            Join the platform where <strong>Citizens</strong> meet <strong>Governance</strong>
                        </p>
                        <div class="step-indicator">
                            <div class="step-indicator__item active" id="si-step1">
                                <div class="step-indicator__dot">1</div>
                                <div class="step-indicator__text">Personal Info</div>
                            </div>
                            <div class="step-indicator__line"></div>
                            <div class="step-indicator__item" id="si-step2">
                                <div class="step-indicator__dot">2</div>
                                <div class="step-indicator__text">Verification</div>
                            </div>
                            <div class="step-indicator__line"></div>
                            <div class="step-indicator__item" id="si-step3">
                                <div class="step-indicator__dot">3</div>
                                <div class="step-indicator__text">Security</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 panel-right">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" enctype="multipart/form-data" autocomplete="off" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="tech-validation-summary" role="alert"></div>
                        <input type="file" id="selfieHiddenInput" name="Input.SelfiePhoto" style="display:none;" accept="image/*" />

                        <div id="step1">
                            <span class="eyebrow">Step 1 of 3</span>
                            <div class="step-title mb-3">Personal Information</div>

                            <div class="mb-2">
                                <label asp-for="Input.FirstName" class="form-text-label">First Name</label>
                                <input asp-for="Input.FirstName" class="form-control tech-input" placeholder="Juan" autocomplete="off" />
                                <span asp-validation-for="Input.FirstName" class="tech-validation"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="Input.MiddleName" class="form-text-label">
                                    Middle Name <span class="optional-tag">(Optional)</span>
                                </label>
                                <input asp-for="Input.MiddleName" class="form-control tech-input" placeholder="Santos" autocomplete="off" />
                            </div>

                            <div class="mb-2">
                                <label asp-for="Input.LastName" class="form-text-label">Last Name</label>
                                <input asp-for="Input.LastName" class="form-control tech-input" placeholder="dela Cruz" autocomplete="off" />
                                <span asp-validation-for="Input.LastName" class="tech-validation"></span>
                            </div>

                            <div class="mb-2">
                                <label asp-for="Input.PhoneNumber" class="form-text-label">Phone Number</label>
                                <div class="phone-wrapper">
                                    <span class="phone-prefix">+63</span>
                                    <input asp-for="Input.PhoneNumber" class="form-control tech-input" placeholder="9XXXXXXXXX" autocomplete="off" maxlength="10" inputmode="numeric" oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                                </div>
                                <span asp-validation-for="Input.PhoneNumber" class="tech-validation"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-text-label">Email Address</label>
                                <input asp-for="Input.Email" class="form-control tech-input" placeholder="name@example.com" autocomplete="off" />
                                <span asp-validation-for="Input.Email" class="tech-validation"></span>
                            </div>

                            <button type="button" id="nextStepButton" class="cta w-100">
                                Next Step <span class="cta-arr ms-2"></span>
                            </button>

                            <div class="mt-2 text-center sign-in-note">
                                Already registered? <a asp-page="./Login" class="tech-link ms-1">Sign in here</a>
                            </div>
                        </div>

                        <div id="step2" style="display:none;">
                            <span class="eyebrow">Step 2 of 3</span>
                            <div class="step-title mb-3">Identity Verification</div>

                            <div id="privacyAgreementSection" class="mb-3">
                                <div class="privacy-agreement-card">
                                    <div class="privacy-agreement__header">
                                        <h4 class="privacy-agreement__title">Data Privacy Consent</h4>
                                        <p class="privacy-agreement__subtitle">Republic Act No. 10173</p>
                                    </div>
                                    <div class="privacy-agreement__content">
                                        <p class="privacy-agreement__intro">
                                            By proceeding with identity verification, you acknowledge that:
                                        </p>
                                        <div class="privacy-terms">
                                            <div class="privacy-term">
                                                <svg class="term-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                                <div>
                                                    <strong>Data Collection & Processing:</strong> Your personal information, including government-issued ID and biometric data (selfie), will be collected and processed solely for identity verification purposes in accordance with RA 10173.
                                                </div>
                                            </div>
                                            <div class="privacy-term">
                                                <svg class="term-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                                <div>
                                                    <strong>Lawful Basis:</strong> Your data is processed under the legitimate purpose of account authentication and compliance with government regulations for the Vox Angelos platform.
                                                </div>
                                            </div>
                                            <div class="privacy-term">
                                                <svg class="term-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                                <div>
                                                    <strong>Data Security:</strong> All data is encrypted and protected using industry-standard security measures. Access is restricted to authorized personnel only.
                                                </div>
                                            </div>
                                            <div class="privacy-term">
                                                <svg class="term-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                                <div>
                                                    <strong>Your Rights:</strong> You have the right to access, correct, or delete your personal data. Contact National Privacy Commission (NPC) for any concerns.
                                                </div>
                                            </div>
                                            <div class="privacy-term">
                                                <svg class="term-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="20 6 9 17 4 12"></polyline>
                                                </svg>
                                                <div>
                                                    <strong>Retention Period:</strong> Your data will be retained for the duration of your account plus 3 years thereafter, in compliance with Philippine law.
                                                </div>
                                            </div>
                                        </div>
                                        <div class="privacy-agreement__consent mt-3">
                                            <div class="consent-checkbox">
                                                <input type="checkbox" id="privacyConsent" name="Input.PrivacyConsent" />
                                                <label for="privacyConsent" class="consent-label ms-2">I have read and agree to the privacy terms</label>
                                            </div>
                                            <span id="privacyConsentError" class="tech-validation" style="display:none;">You must consent to proceed</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="identityFields" style="display:none;">
                                <div class="mb-2">
                                    <label asp-for="Input.IdType" class="form-text-label">ID Type</label>
                                    <select asp-for="Input.IdType" id="idTypeSelect" class="form-select tech-input tech-select" onchange="onIdTypeChange()">
                                        <option value="">— Select ID Type —</option>
                                        <option value="National ID">National ID</option>
                                        <option value="Driver's License">Driver's License</option>
                                        <option value="Passport">Passport</option>
                                        <option value="Voter's ID">Voter's ID</option>
                                    </select>
                                    <span asp-validation-for="Input.IdType" class="tech-validation"></span>
                                </div>

                                <div class="mb-2" id="idPhotoSection" style="display:none;">
                                    <label asp-for="Input.IdPhoto" class="form-text-label">Upload ID Photo</label>
                                    <div class="file-drop-zone" id="fileDropZone">
                                        <input asp-for="Input.IdPhoto" type="file" class="file-input" id="idPhotoInput" accept=".jpg,.jpeg,.png" />
                                        <div class="file-drop-zone__inner">
                                            <svg class="file-drop-zone__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 16V8m0 0-3 3m3-3 3 3M6 20h12a2 2 0 002-2V8l-6-6H6a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                                            <span class="file-drop-zone__text" id="fileLabel">Click to upload · JPG or PNG</span>
                                        </div>
                                    </div>
                                    <span asp-validation-for="Input.IdPhoto" class="tech-validation"></span>
                                </div>

                                <div class="mb-2">
                                    <label class="form-text-label">Live Selfie</label>
                                    <div id="cameraContainer" class="camera-container-neo">
                                        <video id="cameraFeed" autoplay playsinline></video>
                                        <canvas id="capturedCanvas"></canvas>
                                    </div>
                                    <div class="camera-controls" id="cameraControls">
                                        <button type="button" id="btnStartCamera" onclick="startCamera()" class="btn-camera-text">▶ Open Camera</button>
                                        <button type="button" id="btnCapture" onclick="capturePhoto()" class="btn-capture-round" style="display:none;"><div class="inner"></div></button>
                                        <button type="button" id="btnRetake" onclick="retakePhoto()" class="btn-camera-text" style="display:none;">↺ Retake</button>
                                    </div>
                                    <div id="selfieStatus" class="selfie-status"></div>
                                </div>
                            </div>

                            <div class="d-flex gap-3 mt-3">
                                <button type="button" class="cta-back" onclick="goToStep1()">Back</button>
                                <button type="button" id="step2NextBtn" class="cta flex-grow-1" onclick="goToStep3()">
                                    Next Step <span class="cta-arr ms-2"></span>
                                </button>
                            </div>
                        </div>

                        <div id="step3" style="display:none;">
                            <span class="eyebrow">Step 3 of 3</span>
                            <div class="step-title mb-3">Account Security</div>

                            <div class="mb-2">
                                <label asp-for="Input.Password" class="form-text-label">Password</label>
                                <div class="pw-wrapper">
                                    <input asp-for="Input.Password" id="regPassword" class="form-control tech-input w-100" type="password" oninput="checkPasswordRules()" placeholder="••••••••" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('regPassword', this)" tabindex="-1">
                                        <svg id="regPassword-eye" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Input.Password" class="tech-validation"></span>
                                <div class="pw-guidelines">
                                    <div class="pw-rule" id="rule-length"><span class="pw-rule-icon">✕</span> At least 6 characters</div>
                                    <div class="pw-rule" id="rule-upper"><span class="pw-rule-icon">✕</span> At least one uppercase letter</div>
                                    <div class="pw-rule" id="rule-lower"><span class="pw-rule-icon">✕</span> At least one lowercase letter</div>
                                    <div class="pw-rule" id="rule-digit"><span class="pw-rule-icon">✕</span> At least one number</div>
                                    <div class="pw-rule" id="rule-special"><span class="pw-rule-icon">✕</span> At least one special character</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.ConfirmPassword" class="form-text-label">Confirm Password</label>
                                <div class="pw-wrapper">
                                    <input asp-for="Input.ConfirmPassword" id="regConfirmPassword" class="form-control tech-input w-100" type="password" oninput="checkMatch()" placeholder="••••••••" />
                                    <button type="button" class="pw-toggle" onclick="togglePw('regConfirmPassword', this)" tabindex="-1">
                                        <svg id="regConfirmPassword-eye" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                            <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                            <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Input.ConfirmPassword" class="tech-validation"></span>
                                <div class="pw-rule mt-1" id="rule-match" style="display:none;"><span class="pw-rule-icon">✕</span> Passwords match</div>
                            </div>

                            <span id="createAccountGeneralError" class="tech-validation d-block mb-2" style="display:none;"></span>

                            <div class="d-flex gap-3">
                                <button type="button" class="cta-back w-50" onclick="goBackToStep2()">Back</button>
                                <button id="registerSubmit" type="button" class="cta w-50" onclick="submitRegistration()">Create Account</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        let cameraStream = null;
        let selfieCaptured = false;

        // ── Privacy Consent Logic ─────────────────────────────────────
        document.getElementById('privacyConsent').addEventListener('change', function() {
        const privacyCard = document.getElementById('privacyAgreementSection');
        const identityFields = document.getElementById('identityFields');
        document.getElementById('privacyConsentError').style.display = 'none';
            
        if (this.checked) {
        $(privacyCard).fadeOut(300, function() { $(identityFields).fadeIn(400); });
        } else {
        $(identityFields).fadeOut(300, function() { $(privacyCard).fadeIn(400); });
        }
        });

        // ── ID Type Toggle ───────────────────────────────────────────
        function onIdTypeChange() {
        const val = document.getElementById('idTypeSelect').value;
        document.getElementById('idPhotoSection').style.display = val ? 'block' : 'none';
        }

        document.getElementById('idPhotoInput').addEventListener('change', function() {
        const label = document.getElementById('fileLabel');
        label.textContent = this.files.length > 0 ? this.files[0].name : 'Click to upload · JPG or PNG';
        });

        document.getElementById('fileDropZone').addEventListener('click', (e) => {
        if (e.target !== document.getElementById('idPhotoInput')) document.getElementById('idPhotoInput').click();
        });

        // ── Step navigation ───────────────────────────────────────────
        async function goToStep2() {
        let isValid = true;
        ['#Input_FirstName','#Input_LastName','#Input_Email','#Input_PhoneNumber'].forEach(f => { if (!$(f).valid()) isValid = false; });
        if (!isValid) return;

        const btn = document.getElementById('nextStepButton');
        btn.disabled = true; btn.innerHTML = 'Validating...';
        const email = $('#Input_Email').val();
        const phone = '+63' + $('#Input_PhoneNumber').val();

        try {
        const res = await fetch(`?handler=CheckDuplicates&email=${encodeURIComponent(email)}&phone=${encodeURIComponent(phone)}`);
        const data = await res.json();
        $('.custom-duplicate-error').remove();
        if (data.success) { showStep(1, 2); }
        else {
        for (const [id, msg] of Object.entries(data.errors)) {
        $(`#${id}`).after(`<span class="text-danger custom-duplicate-error tech-validation">${msg}</span>`);
        }
        }
        } finally { btn.disabled = false; btn.innerHTML = 'Next Step <span class="cta-arr ms-2"></span>'; }
        }

        document.getElementById('nextStepButton').addEventListener('click', goToStep2);

        async function goToStep3() {
        if (!document.getElementById('privacyConsent').checked) {
        document.getElementById('privacyConsentError').style.display = 'block';
        return;
        }

        const idType = document.getElementById('idTypeSelect').value;
        if (!idType) return showResultModal('error', 'ID Required', 'Please select an ID type.');
        const idInput = document.getElementById('idPhotoInput');
        if (!idInput.files.length) return showResultModal('error', 'Photo Required', 'Please upload your ID photo.');
        if (!selfieCaptured) return setStatus('Live bio-capture required.', 'error');

        const idDimensions = {
        "Driver's License": { ratio: 1.585, label: "Driver's License" },
        "National ID": { ratio: 1.585, label: "National ID" },
        "Voter's ID": { ratio: 1.585, label: "Voter's ID" },
        "Passport": { ratio: 0.75, label: "Passport" }
        };

        // Phones embed an EXIF orientation tag on freshly-taken photos instead of
        // rotating the actual pixel data; browsers honor it for display, but the
        // raw bytes we'd otherwise upload are still sideways. Re-drawing onto a
        // canvas bakes in the on-screen orientation and strips the EXIF tag, the
        // same way the selfie capture already does via canvas.toBlob().
        const normalizedIdPhoto = await normalizeImageOrientation(idInput.files[0]);

        const dimensionOk = await checkIdDimensions(normalizedIdPhoto, idType, idDimensions);
        if (!dimensionOk) return;

        $('#loadingModal').css('display', 'flex');
        const formData = new FormData();
        formData.append('idPhoto', normalizedIdPhoto);
        formData.append('selfiePhoto', document.getElementById('selfieHiddenInput').files[0]);
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        try {
        const res = await fetch('?handler=VerifyIdentity', {
        method: 'POST',
        body: formData,
        headers: { 'RequestVerificationToken': token }
        });
        const data = await res.json();
        $('#loadingModal').hide();
        if (data.success) {
        stopCamera();
        showResultModal('success', 'Verified', 'Identity check successful.', () => showStep(2, 3));
        } else {
        showResultModal('error', 'Failed', data.error || 'Identity could not be confirmed.');
        }
        } catch(e) { $('#loadingModal').hide(); showResultModal('error', 'Error', 'Connection error.'); }
        }

        function normalizeImageOrientation(file) {
        return new Promise((resolve) => {
        const img = new Image();
        img.onload = function() {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        canvas.getContext('2d').drawImage(img, 0, 0);
        URL.revokeObjectURL(img.src);
        canvas.toBlob((blob) => {
        resolve(new File([blob], 'id-photo.jpg', { type: 'image/jpeg' }));
        }, 'image/jpeg', 0.92);
        };
        img.src = URL.createObjectURL(file);
        });
        }

        function checkIdDimensions(file, idType, rules) {
        return new Promise((resolve) => {
        const rule = rules[idType];
        const img = new Image();
        img.onload = function() {
        const ratio = img.naturalWidth / img.naturalHeight;
        if (Math.abs(ratio - rule.ratio) / rule.ratio > 0.25) {
        showResultModal('error', 'Invalid Format', `Upload a ${rule.ratio > 1 ? 'landscape' : 'portrait'} photo of your ${rule.label}.`);
        resolve(false);
        } else resolve(true);
        };
        img.src = URL.createObjectURL(file);
        });
        }

        function showStep(from, to) {
        $(`#step${from}`).hide(); $(`#step${to}`).show();
        $(`#si-step${from}`).removeClass('active').addClass('done');
        $(`#si-step${to}`).addClass('active');
        window.scrollTo(0,0);
        }

        function goToStep1() { stopCamera(); showStep(2, 1); }
        function goBackToStep2() { showStep(3, 2); }

        // ── Final submission (AJAX, no page reload) ────────────────────
        // Kept in-place on Step 3 regardless of which field fails server-side
        // validation (e.g. password policy), instead of doing a native form
        // submit — a full page reload would reset the wizard to Step 1 and
        // wipe the already-selected ID photo / captured selfie, since browsers
        // never restore <input type="file"> values after a navigation.
        async function submitRegistration() {
        document.querySelectorAll('.custom-account-error').forEach(el => el.remove());
        document.getElementById('createAccountGeneralError').style.display = 'none';

        const btn = document.getElementById('registerSubmit');
        const originalText = btn.textContent;
        btn.disabled = true; btn.textContent = 'Creating Account...';

        // Re-check email/phone duplicates right before the real submit — Step 1
        // already checked these, but time has passed (ID/selfie verification in
        // between), so someone else could have taken the same email/phone since
        // then. Catching it here, with a clear popup back to Step 1, is much
        // better than only finding out after this expensive step, buried in an
        // inline message on a step that's no longer visible.
        const email = $('#Input_Email').val();
        const phone = '+63' + $('#Input_PhoneNumber').val();
        try {
        const dupRes = await fetch(`?handler=CheckDuplicates&email=${encodeURIComponent(email)}&phone=${encodeURIComponent(phone)}`);
        const dupData = await dupRes.json().catch(() => null);
        if (dupData && !dupData.success) {
        btn.disabled = false; btn.textContent = originalText;
        $('.custom-duplicate-error').remove();
        for (const [id, msg] of Object.entries(dupData.errors)) {
        $(`#${id}`).after(`<span class="text-danger custom-duplicate-error tech-validation">${msg}</span>`);
        }
        const messages = Object.values(dupData.errors).join(' ');
        showResultModal('error', 'Please Check Your Info', messages, () => showStep(3, 1));
        return;
        }
        } catch (e) {
        // If the duplicate pre-check itself fails to reach the server, fall
        // through to the real submit below — it re-validates the same thing
        // server-side and will surface its own error if still a problem.
        }

        const form = document.getElementById('registerForm');
        const formData = new FormData(form);
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        try {
        const res = await fetch('?handler=CreateAccount', {
        method: 'POST',
        body: formData,
        headers: { 'RequestVerificationToken': token }
        });
        const data = await res.json().catch(() => null);

        if (data?.success) {
        window.location.href = data.redirectUrl;
        return;
        }

        let shown = false;

        if (data?.fieldErrors) {
        for (const [id, msg] of Object.entries(data.fieldErrors)) {
        const field = document.getElementById(id);
        // Fields like Input_PhoneNumber live on Step 1, but this handler only
        // ever runs from Step 3 — if the field's step is currently hidden,
        // inserting the message right after it is invisible to the user (this
        // was the "nothing happens" bug). Always also surface it in the
        // Step 3 general error banner so it's visible regardless of which
        // step the failing field lives on.
        const isVisible = field && field.offsetParent !== null;
        if (field) {
        field.insertAdjacentHTML('afterend', `<span class="text-danger custom-account-error tech-validation">${msg}</span>`);
        }
        if (!isVisible) {
        const el = document.getElementById('createAccountGeneralError');
        el.textContent = (el.textContent ? el.textContent + ' ' : '') + msg;
        el.style.display = 'block';
        }
        shown = true;
        }
        }

        if (data?.generalErrors && data.generalErrors.length) {
        const el = document.getElementById('createAccountGeneralError');
        el.textContent = data.generalErrors.join(' ');
        el.style.display = 'block';
        shown = true;
        }

        // Rate-limiter rejections (and other flat error responses) use
        // {success:false, error:"..."} instead of fieldErrors/generalErrors.
        if (!shown && data?.error) {
        const el = document.getElementById('createAccountGeneralError');
        el.textContent = data.error;
        el.style.display = 'block';
        shown = true;
        }

        // Last resort: something failed (non-2xx, unparseable body, or a shape
        // we don't recognize) but we still haven't shown anything — never let
        // the button just silently reset with no explanation.
        if (!shown) {
        const el = document.getElementById('createAccountGeneralError');
        el.textContent = `Something went wrong (server returned ${res.status}). Please try again.`;
        el.style.display = 'block';
        }
        } catch (e) {
        showResultModal('error', 'Error', 'Connection error. Please try again.');
        } finally {
        btn.disabled = false; btn.textContent = originalText;
        }
        }

        // ── Result Feedback Modal ─────────────────────────────────────
        function showResultModal(type, title, message, callback) {
        const icon = type === 'success' ?
        `<svg viewBox="0 0 100 100" class="svg-icon svg-info"><circle cx="50" cy="50" r="42" stroke="#2B45B0" stroke-width="5" fill="none"/><path d="M50,30 L50,70" stroke="#2B45B0" stroke-width="6" stroke-linecap="round"/></svg>` :
        `<svg viewBox="0 0 100 100" class="svg-icon svg-error"><circle cx="50" cy="50" r="42" stroke="#e53e3e" stroke-width="5" fill="none"/><path d="M34,34 L66,66 M66,34 L34,66" stroke="#e53e3e" stroke-width="6" stroke-linecap="round"/></svg>`;
        $('#resultIcon').html(icon); $('#resultTitle').text(title); $('#resultMessage').text(message);
        $('#resultModal').css('display', 'flex');
        window.onModalClose = callback;
        }

        function closeResultModal() { $('#resultModal').hide(); if(window.onModalClose) window.onModalClose(); }

        // ── Camera Implementation ──────────────────────────────────────
        async function startCamera() {
        try {
        cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: 640 } });
        document.getElementById('cameraFeed').srcObject = cameraStream;
        $('#btnStartCamera').hide(); $('#btnCapture').css('display', 'flex');
        } catch(e) { setStatus('Cam Access Denied.', 'error'); }
        }

        function capturePhoto() {
        const v = document.getElementById('cameraFeed'), c = document.getElementById('capturedCanvas');
        c.width = v.videoWidth; c.height = v.videoHeight;
        c.getContext('2d').drawImage(v, 0, 0);
        $(v).hide(); $(c).show(); $('#btnCapture').hide(); $('#btnRetake').show();
        c.toBlob(blob => {
        const file = new File([blob], 'selfie.jpg', { type: 'image/jpeg' });
        const dt = new DataTransfer(); dt.items.add(file);
        document.getElementById('selfieHiddenInput').files = dt.files;
        selfieCaptured = true; setStatus('Biometric captured.', 'success');
        }, 'image/jpeg', 0.9);
        }

        function retakePhoto() { selfieCaptured = false; $('#capturedCanvas').hide(); $('#cameraFeed').show(); $('#btnRetake').hide(); $('#btnCapture').show(); setStatus('', ''); }
        function stopCamera() { if (cameraStream) cameraStream.getTracks().forEach(t => t.stop()); }
        function setStatus(m, t) { $('#selfieStatus').text(m).removeClass('success error').addClass(t); }

        // ── Security Validation ────────────────────────────────────────
        function togglePw(id) { const i = document.getElementById(id); i.type = i.type === 'password' ? 'text' : 'password'; }
        function checkPasswordRules() {
        const v = $('#regPassword').val();
        setRule('rule-length', v.length >= 6);
        setRule('rule-upper', /[A-Z]/.test(v));
        setRule('rule-lower', /[a-z]/.test(v));
        setRule('rule-digit', /[0-9]/.test(v));
        setRule('rule-special', /[^A-Za-z0-9]/.test(v));
        checkMatch();
        }
        function setRule(id, met) { const el = document.getElementById(id); el.classList.toggle('met', met); el.querySelector('.pw-rule-icon').textContent = met ? '✓' : '✕'; }
        function checkMatch() {
        const p = $('#regPassword').val(), c = $('#regConfirmPassword').val();
        if(!c) return $('#rule-match').hide();
        $('#rule-match').show().toggleClass('met', p === c && p !== '');
        document.getElementById('rule-match').querySelector('.pw-rule-icon').textContent = (p === c && p !== '') ? '✓' : '✕';
        }

        window.addEventListener('load', () => { setTimeout(() => { document.querySelectorAll('input:not([type="hidden"])').forEach(i => i.value = ''); }, 100); });
        window.addEventListener('beforeunload', stopCamera);
    </script>
</body>
</html>
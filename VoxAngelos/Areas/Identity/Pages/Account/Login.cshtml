@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos — Log In</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>

    <div id="notifModal" style="display:none; position:fixed; inset:0; background:#00000030; z-index:9999; align-items:center; justify-content:center;">
        <div style="background:rgba(234, 236, 245, 0.98); border-radius: 20px; padding:2.5rem; max-width:420px; width:90%; text-align:center; box-shadow: inset 1px 2px 2px 0 #ffffff70, inset -1px -2px 2px 0 #00000030, 0 20px 50px rgba(0,0,0,0.3);">
            <div id="notifIcon" style="font-size:3rem; margin-bottom:1rem;"></div>
            <h3 id="notifTitle" style="font-family: var(--font-stack); font-weight: 700; text-transform:uppercase; color:#2B45B0; margin-bottom:0.5rem;"></h3>
            <p id="notifMessage" style="color:#718096; font-size:0.9rem; margin-bottom:1.5rem; line-height:1.6;"></p>
            <button onclick="closeNotifModal()" class="cta" style="width: auto; padding: 10px 40px;">OK</button>
        </div>
    </div>

    <div class="tech-wrapper">
        <div class="row g-0">
            <div class="col-lg-5 panel-left">
                <div class="glass-inner">
                    <span class="sys-label">Vox Angelos</span>
                    <h1 class="portal-title">Citizen<br />Login</h1>
                    <div class="login-subtext">
                        <p class="login-instruction">
                            Log in to access your secure profile, track submitted reports, and continue engaging with Angeles City governance bodies.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 panel-right">
                <section>
                    <span class="eyebrow">Authentication Required</span>
                    <form id="account" method="post" autocomplete="off">

                        <div asp-validation-summary="ModelOnly" class="d-none" id="validationSummary" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-text-label">Email Address</label>
                            <input asp-for="Input.Email" class="form-control tech-input" autocomplete="off" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-text-label">Password</label>
                            <div class="pw-wrapper">
                                <input asp-for="Input.Password" id="loginPassword" class="form-control tech-input w-100" type="password" placeholder="••••••••" />
                                <button type="button" class="pw-toggle" onclick="togglePw('loginPassword', this)" tabindex="-1">
                                    <svg id="loginPassword-eye" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                        <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4 pt-2">
                            <button id="login-submit" type="submit" class="cta">
                                Login
                            </button>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-page="./Register" class="tech-link">Create Account</a>
                            <a href="/Identity/Account/ForgotPassword" class="tech-link">Forgot Password?</a>
                        </div>
                    </form>
                </section>

                <div class="form-footer mt-5 pt-3">
                    <p class="privacy-note">
                        Protected by <strong>RA 10173</strong>. Your data is encrypted and handled in accordance with the Data Privacy Act of the Philippines.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        window.addEventListener('load', function () {
        setTimeout(function () {
        const summary = document.getElementById('validationSummary');
        if (summary) {
        const errors = Array.from(summary.querySelectorAll('li')).map(li => li.textContent.trim()).filter(t => t.length > 0);
        if (errors.length > 0) {
        const msg = errors.join(' ');
        const isPending = msg.toLowerCase().includes('pending') || msg.toLowerCase().includes('approval');

        // PERFECTLY CENTERED 'X' - Accounts for stroke width
        const errorIconSvg = `<svg viewBox="0 0 100 100" class="svg-icon svg-error">
        <circle cx="50" cy="50" r="42" stroke="#e53e3e" stroke-width="5" fill="none"/>
        <path d="M 34 34 L 66 66 M 66 34 L 34 66" stroke="#e53e3e" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>`;

        // Info icon (already perfect)
        const infoIconSvg = `<svg viewBox="0 0 100 100" class="svg-icon svg-info">
        <circle cx="50" cy="50" r="42" stroke="#2B45B0" stroke-width="5" fill="none"/>
        <circle cx="50" cy="32" r="5" fill="#2B45B0"/>
        <rect x="47" y="45" width="6" height="25" rx="1" fill="#2B45B0"/>
        </svg>`;

        if (isPending) {
        showNotifModal(infoIconSvg, 'Under Review', 'Your account is pending admin approval.');
        } else {
        showNotifModal(errorIconSvg, 'Login Failed', msg);
        }
        }
        }
        }, 100);
        });

        function showNotifModal(iconSvg, title, message) {
        const iconContainer = document.getElementById('notifIcon');
        iconContainer.innerHTML = iconSvg;
        document.getElementById('notifTitle').textContent = title;
        document.getElementById('notifMessage').textContent = message;
        document.getElementById('notifModal').style.display = 'flex';
        }

        function closeNotifModal() {
        document.getElementById('notifModal').style.display = 'none';
        }
        
        function togglePw(inputId, btn) {
        const input = document.getElementById(inputId);
        const eye = document.getElementById(inputId + '-eye');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        eye.innerHTML = isHidden
        ? `<path d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />`
        : `<path d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`;
        }
    </script>
</body>
</html>
@page
@model VoxAngelos.Pages.LGU.IndexModel
@{
    Layout = "_LGULayout";
    ViewData["Title"] = "Citizen Concerns";
}
@functions {
    string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s ago";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/lgu_concerns.css" asp-append-version="true" />
}

<div class="content-header">
    <h1 class="page-title">Citizen Concerns</h1>
</div>

<!-- ── Feed header ── -->
<div class="feed-filter-group">
    @{
        var filters = new[] { "Unresolved", "Chosen", "In Progress", "Resolved", "All" };
    }
    @foreach (var f in filters)
    {
        var isActive = Model.CurrentFilter == f ? "active" : "";
        <a class="filter-btn @isActive" href="?filter=@f">@f</a>
    }
</div>

<!-- ── Concern cards (from DB) ── -->
<div id="concern-feed">
    @foreach (var concern in Model.Concerns)
    {
        var statusCss = concern.Status.ToLower().Replace(" ", "-");
        var timeAgo = GetTimeAgo(concern.SubmittedAt);

        <div class="concern-card" data-id="@concern.Id">
            <div class="concern-status @statusCss">
                @concern.Status
            </div>

            <div class="card-header">
                <div class="author-info">
                    <div class="avatar">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                        </svg>
                    </div>
                    <div>
                        <div class="author-name">@concern.CitizenName</div>
                    </div>
                </div>
                <div class="card-date">@timeAgo</div>
            </div>

            <div class="card-meta">
                <span class="meta-label">
                    Category: <span class="meta-value">@concern.Category</span>
                </span>
            </div>

            <div class="card-body">
                <p class="concern-excerpt">@concern.Description</p>
            </div>

            @if (concern.FirstAttachmentPath != null)
            {
                <div class="concern-attachments">
                    <div class="concern-photo">
                        <img src="@concern.FirstAttachmentPath" alt="Concern photo" />
                    </div>
                </div>
            }

            <div class="card-footer-lgu">
                <div class="concern-location">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 2C8.686 2 6 4.686 6 8c0 5.25 6 13 6 13s6-7.75 6-13c0-3.314-2.686-6-6-6z" />
                        <circle cx="12" cy="8" r="2" />
                    </svg>
                    @concern.Latitude, @concern.Longitude
                </div>

                @if (concern.Status == "Unresolved")
                {
                    <div class="action-container">
                        <form method="post" asp-page="/LGU/Index" asp-page-handler="ChooseConcern">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="concernId" value="@concern.Id" />
                            <button type="submit" class="btn-dark-pill">Choose Concern</button>
                        </form>
                    </div>
                }
                else if (concern.Status == "Chosen" || concern.Status == "In Progress")
                {
                    <div class="action-container">
                        <button type="button" class="btn-dark-pill" data-bs-toggle="modal" data-bs-target="#statusModal" onclick="openStatusModal(@concern.Id, '@concern.CitizenName')">
                            Update Status
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.Concerns.Any())
    {
        <div class="feed-empty">
            <p>No concerns submitted yet.</p>
        </div>
    }
</div>


<!-- ── Update Status Modal ── -->
<div class="modal fade modal-va" id="statusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header justify-content-center border-0 pb-0">
                <div class="modal-title text-center" id="statusModalLabel">
                    Update Status for: <span id="modal-citizen-name"></span>
                </div>
                <button type="button" class="btn-close position-absolute end-0 me-3"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page="/LGU/Index" asp-page-handler="UpdateStatus">
                @Html.AntiForgeryToken()
                <input type="hidden" name="concernId" id="modal-concern-id" />

                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <label class="form-label text-center w-100"
                               style="color: var(--accent); font-weight: 600;">New Status</label>
                        <select class="form-select" name="status" id="modal-status-select">
                            <option value="" disabled selected>Status...</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Resolved">Resolved</option>
                        </select>
                    </div>
                    <div class="mb-1">
                        <label class="form-label text-center w-100"
                               style="color: var(--accent); font-weight: 600;">Notes / Public Response</label>
                        <textarea class="form-control" name="notes" id="modal-notes"
                                  placeholder="Add a response to the resident..."></textarea>
                    </div>
                </div>

                <div class="modal-footer justify-content-center border-0">
                    <button type="button" class="btn-va-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-va-primary">Save Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let activeCard = null;

        // ── Open Status Modal ──
        function openStatusModal(concernId, citizenName) {
            document.getElementById('modal-citizen-name').textContent = citizenName;
            document.getElementById('modal-concern-id').value = concernId;
            document.getElementById('modal-status-select').value = '';
            document.getElementById('modal-notes').value = '';
        }

        // ── Choose Concern → reveal Update Status ──
        document.getElementById('concern-feed').addEventListener('click', function (e) {
            const chooseBtn = e.target.closest('.btn-choose-concern');
            if (chooseBtn) {
                const card = chooseBtn.closest('.concern-card');
                chooseBtn.style.display = 'none';
                card.querySelector('.btn-update-status').style.display = 'inline-flex';

                const banner = document.createElement('div');
                banner.className = 'concern-selected-banner';
                banner.textContent = 'Selected';
                card.querySelector('.concern-card-body').prepend(banner);
                return;
            }
        });

        // ── Auto-refresh feed every 15 seconds ──
        setInterval(() => {
            fetch(window.location.href)
                .then(res => res.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newFeed = doc.getElementById('concern-feed');
                    const currentFeed = document.getElementById('concern-feed');

                    if (newFeed && currentFeed) {
                        const newCount = newFeed.querySelectorAll('.concern-card').length;
                        const currentCount = currentFeed.querySelectorAll('.concern-card').length;
                        if (newCount !== currentCount) {
                            currentFeed.innerHTML = newFeed.innerHTML;
                        }
                    }
                })
                .catch(() => { });
        }, 15000);
    </script>
}

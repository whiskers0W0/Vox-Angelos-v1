@page
@model VoxAngelos.Pages.LGU.LoginOtpModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos | LGU OTP</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Syne+Mono&family=Barlow:wght@300;400&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/lgu-login.css" asp-append-version="true" />
</head>
<body>
    <div class="bg"></div>
    <div class="bg-grid"></div>
    <div class="corner c-tl"></div>
    <div class="corner c-tr"></div>
    <div class="corner c-bl"></div>
    <div class="corner c-br"></div>

    <div class="tech-wrapper">
        <div class="row g-0">
            <div class="col-lg-5 panel-left">
                <div class="eyebrow mb-2">Vox Angelos</div>
                <h1 class="title mb-3">LGU<br />Portal</h1>
                <p class="tagline mb-0">
                    Identity verification<br />
                    <strong>authorized personnel</strong>
                </p>
            </div>

            <div class="col-lg-7 panel-right">
                <div class="eyebrow mb-3">Identity Verification</div>
                <h2 style="font-family:var(--font-oswald); font-weight:700; font-size:1.8rem; color:var(--color-primary); letter-spacing:0.02em; margin-bottom:0.5rem; text-transform:uppercase;">
                    Confirm Access
                </h2>
                <p style="font-family:var(--font-stack); font-size:0.9rem; color:var(--color-text-sub); margin-bottom:2rem; line-height:1.6;">
                    A 6-digit verification code has been sent. Enter it below to authorize this session.
                </p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="error-alert">
                        <p style="font-family: var(--font-stack); font-size:0.75rem; color:var(--color-error); margin:0; font-weight:700; text-transform:uppercase; letter-spacing:0.02em;">
                            ⚠️ @Model.ErrorMessage
                        </p>
                    </div>
                }

                <form method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label for="OtpCode" class="form-text-label d-block mb-1">Verification Code</label>
                        <input type="text"
                               id="OtpCode"
                               name="OtpCode"
                               class="form-control tech-input w-100"
                               placeholder="——————"
                               maxlength="6"
                               inputmode="numeric"
                               autocomplete="off"
                               required />
                    </div>

                    <div class="mb-4">
                        <button type="submit" class="cta w-100">
                            Verify &amp; Sign In
                            <span class="cta-arr ms-2"></span>
                        </button>
                    </div>

                    <div style="text-align:center;">
                        <a href="/LGU/Login" style="font-family:var(--font-stack); font-size:0.8rem; color:var(--color-text-sub);">
                            Back to login
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

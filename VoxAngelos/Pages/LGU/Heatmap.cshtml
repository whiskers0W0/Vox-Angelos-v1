@page
@model VoxAngelos.Pages.LGU.HeatmapModel
@{
    Layout = "_LGULayout";
    ViewData["Title"] = "Map View";
}

@section Styles {
    <link rel="stylesheet" href="~/css/lgu_heatmap.css" asp-append-version="true" />
    <style>
        .info-window {
            font-family: sans-serif;
            font-size: 13px;
            max-width: 220px;
            line-height: 1.5;
        }
        .info-window .iw-name {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 4px;
        }
        .info-window .iw-status {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            margin-bottom: 6px;
            background: #e0e0e0;
            color: #333;
        }
        .info-window .iw-status.unresolved { background:#fff3cd; color:#856404; }
        .info-window .iw-status.chosen { background:#cfe2ff; color:#084298; }
        .info-window .iw-status.in-progress { background:#d1ecf1; color:#0c5460; }
        .info-window .iw-status.resolved { background:#d4edda; color:#155724; }
        .info-window .iw-label { color: #666; font-size: 11px; }
        .info-window .iw-value { color: #222; margin-bottom: 4px; }

        #choropleth-map {
            width: 100%;
            height: 100%;
        }

    </style>
}

<div class="content-header">
    <h1 class="page-title">Concern Locations</h1>
</div>

<!-- Toggle Tabs -->
<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="locations">Locations</button>
    <button class="tab-btn" data-view="heatmap">Heatmap</button>
</div>

<!-- Concern Locations View -->
<div class="locations-wrapper">
    <div id="map"></div>
</div>

<!-- Heatmap View -->
<div class="heatmap-wrapper" style="display:none;">
    <div id="choropleth-map"></div>
</div>

@section Scripts {
    <script>
        const concerns = @Html.Raw(Model.ConcernsJson)

        // ── Tab Switching ──
            document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const view = this.dataset.view;
        
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                const tabGroup = document.querySelector('.tab-group');
                const indicator = tabGroup.querySelector('.tab-indicator');
                const btnIndex = Array.from(document.querySelectorAll('.tab-btn')).indexOf(this);
                indicator.style.transform = `translateX(calc(${btnIndex} * (100% + 8px)))`;

                if (view === 'locations') {
                    document.querySelector('.locations-wrapper').style.display = 'block';
                    document.querySelector('.heatmap-wrapper').style.display = 'none';
                } else {
                document.querySelector('.locations-wrapper').style.display = 'none';
                document.querySelector('.heatmap-wrapper').style.display = 'block';
                initHeatmap();
                // Trigger resize so map fills container correctly
                setTimeout(() => {
                    google.maps.event.trigger(document.getElementById('choropleth-map').__gm?.map ?? {}, 'resize');
                }, 100);
                }
            });
        });

        function initMap() {
            const angelesCityCenter = { lat: 15.1450, lng: 120.5887 };

            const angelesBounds = new google.maps.LatLngBounds(
                new google.maps.LatLng(15.0800, 120.4700),
                new google.maps.LatLng(15.2200, 120.6500)
            );

            const map = new google.maps.Map(document.getElementById('map'), {
                center: angelesCityCenter,
                zoom: 13,
                minZoom: 12,
                maxZoom: 17,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: true,
                zoomControl: true,
                restriction: {
                    latLngBounds: angelesBounds,
                    strictBounds: false
                },
                styles: [
                    {
                        featureType: 'poi',
                        elementType: 'labels',
                        stylers: [{ visibility: 'off' }]
                    }
                ]
            });

            const infoWindow = new google.maps.InfoWindow();

            // Status color mapping
            function getMarkerColor(status) {
                switch (status) {
                    case 'Unresolved': return 'http://maps.google.com/mapfiles/ms/icons/red-dot.png';
                    case 'Chosen': return 'http://maps.google.com/mapfiles/ms/icons/blue-dot.png';
                    case 'In Progress': return 'http://maps.google.com/mapfiles/ms/icons/yellow-dot.png';
                    case 'Resolved': return 'http://maps.google.com/mapfiles/ms/icons/green-dot.png';
                    default: return 'http://maps.google.com/mapfiles/ms/icons/red-dot.png';
                }
            }

            function getStatusClass(status) {
                return status.toLowerCase().replace(' ', '-');
            }

            // Place markers
            concerns.forEach(concern => {
                const marker = new google.maps.Marker({
                    position: { lat: concern.lat, lng: concern.lng },
                    map: map,
                    icon: getMarkerColor(concern.status),
                    title: concern.citizenName
                });

                const content = `
                    <div class="info-window">
                        <div class="iw-name">${concern.citizenName}</div>
                        <span class="iw-status ${getStatusClass(concern.status)}">${concern.status}</span>
                        <div class="iw-label">Category</div>
                        <div class="iw-value">${concern.category}</div>
                        <div class="iw-label">Location</div>
                        <div class="iw-value">${concern.location}</div>
                        <div class="iw-label">Description</div>
                        <div class="iw-value">${concern.description}</div>
                        <div class="iw-label">Submitted</div>
                        <div class="iw-value">${concern.submittedAt}</div>
                    </div>
                `;

                // Show on hover
                marker.addListener('mouseover', () => {
                    infoWindow.setContent(content);
                    infoWindow.open(map, marker);
                });

                // Close on mouseout
                marker.addListener('mouseout', () => {
                    infoWindow.close();
                });

                // Keep open on click
                marker.addListener('click', () => {
                    infoWindow.setContent(content);
                    infoWindow.open(map, marker);
                });
            });
        }

        let choroplethInitialized = false;

        function initHeatmap() {
            if (choroplethInitialized) return;
            choroplethInitialized = true;

            const angelesCityCenter = { lat: 15.1450, lng: 120.5887 };

            const angelesBounds = new google.maps.LatLngBounds(
                new google.maps.LatLng(15.0800, 120.4700), // SW corner
                new google.maps.LatLng(15.2200, 120.6500)  // NE corner
            );

            const map = new google.maps.Map(document.getElementById('choropleth-map'), {
                center: angelesCityCenter,
                zoom: 13,
                minZoom: 12,
                maxZoom: 17,
                mapTypeControl: false,
                streetViewControl: false,
                fullscreenControl: true,
                zoomControl: true,
                restriction: {
                    latLngBounds: angelesBounds,
                    strictBounds: false
                },
                styles: [{ featureType: 'poi', elementType: 'labels', stylers: [{ visibility: 'off' }] }]
            });

            function normalizeStr(str) {
                return str.toLowerCase()
                    .replace(/\./g, '')
                    .replace(/\(.*?\)/g, '')
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function matchBarangay(locationName, featureName) {
                const loc = normalizeStr(locationName);
                const feat = normalizeStr(featureName);
                return loc.includes(feat);
            }

            function getChoroColor(count) {
                if (count === 0)  return '#f7f7f7';
                if (count <= 2)   return '#fdd49e';
                if (count <= 5)   return '#fdbb84';
                if (count <= 10)  return '#fc8d59';
                if (count <= 20)  return '#e34a33';
                return '#b30000';
            }

            fetch('/geojson/angeles-city-barangays.geojson')
    .then(res => res.json())
    .then(geojson => {

        geojson.features.forEach(feature => {
            const barangayName = feature.properties.name;
            let count = 0;
            concerns.forEach(concern => {
                if (concern.location && matchBarangay(concern.location, barangayName)) {
                    count++;
                }
            });
            feature.properties.concernCount = count;
        });

        map.data.addGeoJson(geojson);

        map.data.setStyle(feature => {
            const count = feature.getProperty('concernCount') || 0;
            return {
                fillColor: getChoroColor(count),
                fillOpacity: 0.7,
                strokeColor: '#333',
                strokeWeight: 1
            };
        });

        const infoWindow = new google.maps.InfoWindow();

        map.data.addListener('mouseover', function(event) {
            const name = event.feature.getProperty('name');
            const count = event.feature.getProperty('concernCount') || 0;
            map.data.overrideStyle(event.feature, { strokeWeight: 2.5, strokeColor: '#000' });
            infoWindow.setContent(`
                <div style="font-family:sans-serif; padding:4px;">
                    <strong>${name}</strong><br/>
                    Concerns: <b>${count}</b>
                </div>
            `);
            infoWindow.setPosition(event.latLng);
            infoWindow.open(map);
        });

        map.data.addListener('mouseout', function() {
            map.data.revertStyle();
            infoWindow.close();
        });

    });

            const legend = document.createElement('div');
            legend.style.cssText = `
                background: white; padding: 10px 14px; margin: 10px;
                border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.2);
                font-family: sans-serif; font-size: 12px; line-height: 1.8;
            `;
            legend.innerHTML = `
                <strong style="display:block; margin-bottom:6px;">Concerns per Barangay</strong>
                <span style="background:#f7f7f7;padding:1px 10px;border:1px solid #ccc;">&nbsp;</span> 0<br>
                <span style="background:#fdd49e;padding:1px 10px;">&nbsp;</span> 1–2<br>
                <span style="background:#fdbb84;padding:1px 10px;">&nbsp;</span> 3–5<br>
                <span style="background:#fc8d59;padding:1px 10px;">&nbsp;</span> 6–10<br>
                <span style="background:#e34a33;padding:1px 10px;">&nbsp;</span> 11–20<br>
                <span style="background:#b30000;padding:1px 10px;color:white;">&nbsp;</span> 21+
            `;
            map.controls[google.maps.ControlPosition.RIGHT_BOTTOM].push(legend);
        }
    </script>

    <script src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&callback=initMap" async defer></script>
}
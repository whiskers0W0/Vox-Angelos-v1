@page
@model VoxAngelos.Pages.LGU.LeaderboardModel
@{
    Layout = "_LGULayout";
    ViewData["Title"] = "Top Project Recommendations";
}

@section Styles {
    <link rel="stylesheet" href="~/css/lgu_leaderboard.css" asp-append-version="true" />
}

<div class="content-header">
    <h1 class="page-title">Citizen Recommendations</h1>
</div>

<div id="leaderboardView" class="view-section">
    <div class="leaderboard-wrapper">

        <div class="leaderboard-feed">

            @if (!Model.TopRated.Any())
            {
                <div style="text-align:center;padding:60px;color:#888;">
                    <p>No approved recommendations yet.</p>
                </div>
            }

            @for (int rank = 0; rank < Model.TopRated.Count; rank++)
            {
                var rec = Model.TopRated[rank];
                <div class="leaderboard-item">
                    <div class="rank-col">
                        <div class="rank-arrow @(rank == 0 ? "up" : "down")">@(rank == 0 ? "▲" : "▼")</div>
                        <div class="rank-number">@(rank + 1)</div>
                    </div>
                    <div class="proposal-card leaderboard-card">
                        <div class="card-header">
                            <div class="author-info">
                                <div class="avatar">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <circle cx="12" cy="8" r="4" />
                                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="author-name">@rec.CitizenName</div>
                                </div>
                            </div>
                            <div class="card-date">@rec.ApprovedAt.ToString("MM/dd/yy")</div>
                        </div>

                        <div class="card-meta">
                            <span class="meta-label">Category: <span class="meta-value">@rec.Category</span></span>
                            @if (!string.IsNullOrEmpty(rec.AssignedOffice))
                            {
                                <span class="meta-label">Office: <span class="meta-value">@rec.AssignedOffice</span></span>
                            }
                        </div>

                        <div class="card-body">
                            <h3 class="proposal-title">Citizen Recommendation: @rec.Title</h3>
                            <p class="proposal-excerpt" id="desc-@rec.Id">@rec.Description</p>
                            <a href="#" class="view-more" id="viewmore-@rec.Id" style="display:none;" 
                               onclick="toggleViewMore(event, '@rec.Id')">View More</a>
                        </div>

                        @if (rec.AttachmentPaths.Any())
                        {
                            <div class="attachments">
                                @{
                                    var maxShow = Math.Min(2, rec.AttachmentPaths.Count);
                                    var extra = rec.AttachmentPaths.Count - maxShow;
                                }
                                @for (int i = 0; i < maxShow; i++)
                                {
                                    var path = rec.AttachmentPaths[i];
                                    var type = rec.AttachmentTypes[i];
                                    <div class="attachment-thumb">
                                        @if (type == "image" || type.StartsWith("image/"))
                                        {
                                            <img src="@path" alt="attachment"
                                                 style="width:100%;height:100%;object-fit:cover;border-radius:8px;cursor:pointer;"
                                                 onclick="openLightbox('@path', 'image')" />
                                        }
                                        else if (type == "video" || type.StartsWith("video/"))
                                        {
                                            <video src="@path"
                                                   style="width:100%;height:100%;border-radius:8px;cursor:pointer;"
                                                   onclick="openLightbox('@path', 'video')"></video>
                                        }
                                        else
                                        {
                                            <a href="@path" target="_blank"
                                               style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;background:#f0f4ff;border-radius:8px;font-size:12px;color:#2D46B9;text-decoration:none;">
                                                📄
                                            </a>
                                        }
                                    </div>
                                }
                                @if (extra > 0)
                                {
                                    <div class="attachment-thumb more-files">
                                        <span>@extra+</span>
                                        <small>Files</small>
                                    </div>
                                }
                            </div>
                        }

                        <div class="leaderboard-votes rating-summary">
                            <span class="rating-chip urgency">Urgency @rec.AvgUrgency.ToString("0.0")★</span>
                            <span class="rating-chip relevance">Relevance @rec.AvgRelevance.ToString("0.0")★</span>
                            <span class="rating-chip feasibility">Feasibility @rec.AvgFeasibility.ToString("0.0")★</span>
                            <span class="rating-count">@rec.RatingCount rating@(rec.RatingCount == 1 ? "" : "s")</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <aside class="ranking-sidebar">
            <div class="ranking-box">
                <div class="ranking-header">
                    <svg class="trophy-icon" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18 2H6a2 2 0 00-2 2v2c0 2.21 1.79 4 4 4h1v2c0 2.33 1.59 4.28 3.74 4.83C12.3 19.46 11 21.08 11 23h2c0-1.92-1.3-3.54-1.74-4.17 2.15-.55 3.74-2.5 3.74-4.83v-2h1c2.21 0 4-1.79 4-4V4a2 2 0 00-2-2zM6 8c-1.1 0-2-.9-2-2V4h2v4zm14-2c0 1.1-.9 2-2 2V4h2v2z" />
                    </svg>
                    <h2 class="ranking-title">TOP 10 RECOMMENDATIONS <br /> (ALL TIME)</h2>
                </div>

                <div class="ranking-list">
                    @if (!Model.TopRated.Any())
                    {
                        <p style="color:#888;font-size:13px;text-align:center;padding:16px;">No data yet.</p>
                    }
                    @for (int i = 0; i < Model.TopRated.Count; i++)
                    {
                        var r = Model.TopRated[i];
                        var shortTitle = r.Title.Length > 22 ? r.Title.Substring(0, 22) + "..." : r.Title;
                        <div class="mini-rank-item">
                            <span class="mini-number">@(i + 1)</span>
                            <div class="mini-content">
                                <p class="mini-title">@shortTitle</p>
                                <div class="mini-votes">
                                    <span class="up">@r.CompositeScore.ToString("0.0")★ <small>score</small></span>
                                    <span class="down">@r.RatingCount <small>ratings</small></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>


<!-- Lightbox Modal -->
<div id="lightboxOverlay" onclick="closeLightbox()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;align-items:center;justify-content:center;">
    <button onclick="closeLightbox()"
            style="position:absolute;top:20px;right:28px;background:none;border:none;color:white;font-size:32px;cursor:pointer;line-height:1;">
        ✕
    </button>
    <div onclick="event.stopPropagation()" style="max-width:90vw;max-height:90vh;display:flex;align-items:center;justify-content:center;">
        <img id="lightboxImg" src="" alt=""
             style="display:none;max-width:90vw;max-height:90vh;border-radius:12px;object-fit:contain;" />
        <video id="lightboxVideo" src="" controls
               style="display:none;max-width:90vw;max-height:90vh;border-radius:12px;"></video>
    </div>
</div>


@section Scripts {
    <script>
               document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.proposal-excerpt').forEach(desc => {
                const id = desc.id.replace('desc-', '');
                const btn = document.getElementById('viewmore-' + id);
                if (desc.scrollHeight > desc.clientHeight) {
                    btn.style.display = 'inline';
                }
            });
        });

        function toggleViewMore(e, id) {
            e.preventDefault();
            const desc = document.getElementById('desc-' + id);
            const btn = document.getElementById('viewmore-' + id);
            const isCollapsed = desc.classList.contains('expanded');
            desc.classList.toggle('expanded');
            btn.textContent = isCollapsed ? 'View More' : 'View Less';
        }


    function openLightbox(src, type) {
        const overlay = document.getElementById('lightboxOverlay');
        const img = document.getElementById('lightboxImg');
        const video = document.getElementById('lightboxVideo');

        img.style.display = 'none';
        video.style.display = 'none';
        video.pause();

        if (type === 'image') {
            img.src = src;
            img.style.display = 'block';
        } else if (type === 'video') {
            video.src = src;
            video.style.display = 'block';
        }

        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        const overlay = document.getElementById('lightboxOverlay');
        const video = document.getElementById('lightboxVideo');
        video.pause();
        overlay.style.display = 'none';
        document.body.style.overflow = '';
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });

    </script>
}

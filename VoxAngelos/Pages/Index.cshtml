@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vox Angelos</title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Syne+Mono&family=Barlow:wght@300;400&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
</head>
<body>

    <!-- Background layers -->
    <div class="bg position-fixed top-0 start-0 w-100 h-100" style="z-index:0"></div>
    <div class="bg-grid position-fixed top-0 start-0 w-100 h-100" style="z-index:1"></div>
    <div class="bg-vig position-fixed top-0 start-0 w-100 h-100" style="z-index:2"></div>

    <!-- Scanline -->
    <div class="scanline position-fixed" style="z-index:200"></div>

    <!-- Corner accents -->
    <div class="corner c-tl position-fixed" style="z-index:30"></div>
    <div class="corner c-tr position-fixed" style="z-index:30"></div>
    <div class="corner c-bl position-fixed" style="z-index:30"></div>
    <div class="corner c-br position-fixed" style="z-index:30"></div>

    <!-- Status bar -->
    <div class="status-bar position-fixed start-0 end-0 d-flex align-items-center justify-content-center gap-2" style="z-index:30">
        <div class="s-pip rounded-circle"></div>
        <div class="s-text">Official Government Portal &nbsp;·&nbsp; Secure Channel</div>
        <div class="s-pip rounded-circle"></div>
    </div>

    <!-- Main stage -->
    <div class="stage position-relative d-flex flex-column align-items-center justify-content-center text-center w-100" style="z-index:10">

        <!-- Radar -->
        <div class="radar-wrap position-relative flex-shrink-0">
            <div class="r-dish">
                <div class="r-ring r-ring-1"></div>
                <div class="r-ring r-ring-2"></div>
                <div class="r-ring r-ring-3"></div>
                <div class="r-cross"></div>
                <div class="r-sweep"></div>
            </div>
            <div class="r-ping r-ping-1"></div>
            <div class="r-ping r-ping-2"></div>
            <div class="r-ping r-ping-3"></div>
            <div class="r-logo d-flex align-items-center justify-content-center">
                <img src="~/assets/logo-no-name.svg" alt="Vox Angelos logo" />
            </div>
        </div>

        <!-- Title -->
        <div class="title-wrap w-100 text-center">
            <span class="title d-inline-block">Vox Angelos</span>
        </div>

        <!-- Eyebrow -->
        <div class="eyebrow w-100">Citizen &nbsp;·&nbsp; Voice &nbsp;·&nbsp; Governance</div>

        <!-- Tagline -->
        <div class="tagline w-100 text-center">
            Where <strong>Citizens</strong> meet <strong>Governance</strong>
        </div>

        <!-- CTA -->
        <a asp-area="Identity" asp-page="/Account/Login" class="cta btn d-inline-flex align-items-center flex-shrink-0">
            Enter Portal
            <span class="cta-arr ms-2"></span>
        </a>

    </div>

    <!-- Footer badges -->
    <div class="footer-bar position-fixed start-0 end-0 d-flex align-items-center justify-content-center flex-wrap gap-2 px-3" style="z-index:30">
        <div class="f-badge d-flex align-items-center gap-1"><span class="f-pip rounded-circle"></span>Secure Connection</div>
        <div class="f-sep"></div>
        <div class="f-badge d-flex align-items-center gap-1"><span class="f-pip rounded-circle"></span>Official Use Only</div>
        <div class="f-sep"></div>
        <div class="f-badge d-flex align-items-center gap-1"><span class="f-pip rounded-circle"></span>Encrypted</div>
    </div>

    <!-- Copyright -->
    <div class="copyright position-fixed start-0 end-0 text-center" style="z-index:30">
        &copy; 2025 Vox Angelos &nbsp;·&nbsp; Authorized Personnel Only
    </div>

    <!-- Bootstrap 5 JS bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

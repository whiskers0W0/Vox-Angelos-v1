@page
@model VoxAngelos.Pages.Admin.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard — Vox Angelos</title>
    <link rel="stylesheet" href="~/css/dashboard_admin.css" />
</head>
<body>
    <div class="admin-wrapper">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <span class="logo-icon">🦅</span>
                <span class="logo-text">Vox Angelos</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/Admin/Index" class="nav-item active">Dashboard</a>
                <a href="/Admin/UserApplications" class="nav-item">User Applications</a>
                <a href="/Admin/OfficeManagement" class="nav-item">Office Management</a>
                <a href="/Admin/ReviewProjects" class="nav-item">Review Projects</a>
            </nav>
            <form method="post" action="/Identity/Account/Logout" class="logout-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="/Admin/Login" />
                <button type="submit" class="btn-logout">⬛ Log Out</button>
            </form>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="page-header">
                <h1>Welcome, Admin!</h1>
            </div>

            <!-- Stats Cards -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">⚠</div>
                    <div class="stat-number">@Model.UnreviewedProjects</div>
                    <div class="stat-label">Unreviewed Projects</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">⊖</div>
                    <div class="stat-number">@Model.UnverifiedAccounts</div>
                    <div class="stat-label">Unverified Accounts</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">✔</div>
                    <div class="stat-number">@Model.VerifiedAccounts</div>
                    <div class="stat-label">Verified Accounts</div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
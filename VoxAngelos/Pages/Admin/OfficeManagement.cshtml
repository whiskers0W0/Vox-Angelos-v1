@page
@model VoxAngelos.Pages.Admin.OfficeManagementModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Office Management";
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin-officemanagement.css" />
}

<div class="content-header">
    <h1 class="page-title">Welcome, Admin</h1>
    <button onclick="showCreateModal()" class="btn-create">+ Create</button>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert-error">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert-success">@Model.SuccessMessage</div>
}

<!-- LGU Accounts Table -->
<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>Department/Office</th>
                <th>Employee ID</th>
                <th>Office Email</th>
                <th>Created</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.LguAccounts.Any())
            {
                <tr>
                    <td colspan="6" class="empty-row">No LGU accounts found.</td>
                </tr>
            }
            @foreach (var account in Model.LguAccounts)
            {
                <tr>
                    <td>
                        @account.Department
                        @if (account.IsSeeded)
                        {
                            <span class="seeded-badge">Seeded</span>
                        }
                    </td>
                    <td>@account.EmployeeId</td>
                    <td>@account.Email</td>
                    <td>@account.CreatedAt.ToString("MM/dd/yyyy")</td>
                    <td>
                        <span class="status-badge @(account.IsActive ? "status-approved" : "status-rejected")">
                            @(account.IsActive ? "Active" : "Disabled")
                        </span>
                    </td>
                    <td>
                        <button type="button"
                                class="btn-edit"
                                data-userid="@account.UserId"
                                data-employeeid="@account.EmployeeId"
                                data-email="@account.Email"
                                data-department="@account.Department"
                                onclick="showEditModalFromBtn(this)">Edit</button>
                        <form method="post" asp-page-handler="ToggleStatus" style="display:inline">
                            <input type="hidden" name="userId" value="@account.UserId" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-review @(account.IsActive ? "btn-disable" : "btn-enable")">
                                @(account.IsActive ? "Disable" : "Enable")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ═══════════════════ CREATE MODAL ═══════════════════ -->
<div id="createModal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Create LGU Office Account</h3>
            <button onclick="closeMainModals()" class="modal-close">✕</button>
        </div>
        <form method="post" asp-page-handler="Create">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Department/Office</label>
                <select name="NewDepartment" class="form-control" required>
                    <option value="">-- Select Department --</option>
                    <option value="SWDO">SWDO</option>
                    <option value="CEO">CEO</option>
                    <option value="CENRO">CENRO</option>
                    <option value="ACDO">ACDO</option>
                    <option value="PPTRO">PPTRO</option>
                    <option value="OSCA">OSCA</option>
                    <option value="PWDAO">PWDAO</option>
                </select>
            </div>
            <div class="form-group">
                <label>Employee ID</label>
                <input type="text" name="NewEmployeeId" class="form-control" placeholder="e.g. LGU-SWDO-002" required />
            </div>
            <div class="form-group">
                <label>Office Email</label>
                <input type="email" name="NewEmail" class="form-control" placeholder="e.g. swdo@voxangelos.gov.ph" required />
            </div>
            <p class="default-pass-note">Account will be created with the default password: <strong>Lgu@123456</strong></p>
            <div class="modal-actions">
                <button type="button" onclick="closeMainModals()" class="btn-cancel">Cancel</button>
                <button type="submit" class="btn-approve">Create Account</button>
            </div>
        </form>
    </div>
</div>

<!-- ═══════════════════ EDIT MODAL ═══════════════════ -->
<div id="editModal" class="modal-overlay" style="display:none">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Edit LGU Account</h3>
            <button onclick="closeMainModals()" class="modal-close">✕</button>
        </div>
        <form id="editForm" method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editUserId" name="EditUserId" />
            <div class="form-group">
                <label>Employee ID</label>
                <input type="text" id="editEmployeeId" name="EditEmployeeId" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Office Email</label>
                <input type="email" id="editEmail" name="EditEmail" class="form-control" required />
            </div>
            <div class="form-group">
                <label>New Password <span class="form-hint-inline">(leave blank to keep current)</span></label>
                <input type="password" id="editPassword" name="EditPassword" class="form-control" placeholder="Leave blank to keep current" />
            </div>
            <div class="modal-actions-split">
                <div class="action-group">
                    <button type="button" onclick="showResetWarning()" class="btn-warning">Reset Password</button>
                    <button type="button" onclick="showDeleteWarning()" class="btn-danger">Delete Account</button>
                </div>
                <div class="action-group">
                    <button type="button" onclick="closeMainModals()" class="btn-cancel" style="flex:0 0 auto;min-width:80px;">Cancel</button>
                    <button type="button" onclick="showSaveWarning()" class="btn-approve" style="flex:0 0 auto;min-width:120px;">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- ═══════════════════ WARNING: SAVE CHANGES ═══════════════════ -->
<div id="saveWarningModal" class="modal-overlay" style="display:none;z-index:1010">
    <div class="modal-box warning-modal">
        <div class="modal-header">
            <h3 class="warning-title">Confirm Changes</h3>
        </div>
        <div class="warning-body">
            <p>You are about to update credentials for the <strong id="saveDeptName"></strong> account.</p>
            <p>To confirm, type the department name below:</p>
            <p class="warning-target" id="saveTargetLabel"></p>
            <div class="confirm-input-group">
                <input type="text" id="saveConfirmInput" class="form-control"
                       placeholder="Type department name to confirm"
                       oninput="checkSaveConfirm()" />
            </div>
        </div>
        <div class="modal-actions">
            <button type="button" onclick="closeSaveWarning()" class="btn-cancel">Cancel</button>
            <button type="button" onclick="confirmSave()" class="btn-approve" id="confirmSaveBtn" disabled>Save Changes</button>
        </div>
    </div>
</div>

<!-- ═══════════════════ WARNING: RESET PASSWORD ═══════════════════ -->
<div id="resetWarningModal" class="modal-overlay" style="display:none;z-index:1010">
    <div class="modal-box warning-modal">
        <div class="modal-header">
            <h3 class="warning-title">Reset Password</h3>
        </div>
        <div class="warning-body">
            <p>This will reset the password for <strong id="resetDeptName"></strong> to the default:</p>
            <p class="warning-target">Lgu@123456</p>
            <p>Type <strong>RESET PASSWORD</strong> to confirm:</p>
            <div class="confirm-input-group">
                <input type="text" id="resetConfirmInput" class="form-control"
                       placeholder="Type RESET PASSWORD"
                       oninput="checkResetConfirm()" />
            </div>
        </div>
        <div class="modal-actions">
            <button type="button" onclick="closeResetWarning()" class="btn-cancel">Cancel</button>
            <button type="button" onclick="confirmReset()" class="btn-warning" id="confirmResetBtn" disabled>Reset Password</button>
        </div>
    </div>
</div>

<!-- ═══════════════════ WARNING: DELETE ACCOUNT ═══════════════════ -->
<div id="deleteWarningModal" class="modal-overlay" style="display:none;z-index:1010">
    <div class="modal-box warning-modal warning-modal-delete">
        <div class="modal-header">
            <h3 class="warning-title warning-title-delete">Delete Account</h3>
        </div>
        <div class="warning-body">
            <p>This action <strong>cannot be undone</strong>. This will permanently delete the <strong id="deleteDeptName"></strong> account.</p>
            <p>To confirm, type the department name:</p>
            <p class="warning-target warning-target-delete" id="deleteTargetLabel"></p>
            <div class="confirm-input-group">
                <input type="text" id="deleteConfirmInput" class="form-control"
                       placeholder="Type department name to confirm"
                       oninput="checkDeleteConfirm()" />
            </div>
        </div>
        <div class="modal-actions">
            <button type="button" onclick="closeDeleteWarning()" class="btn-cancel">Cancel</button>
            <button type="button" onclick="confirmDelete()" class="btn-danger" id="confirmDeleteBtn" disabled>Delete Account</button>
        </div>
    </div>
</div>

<!-- Hidden forms for Reset and Delete (outside edit modal) -->
<form id="resetForm" method="post" asp-page-handler="Reset" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="resetUserId" name="userId" />
</form>

<form id="deleteForm" method="post" asp-page-handler="Delete" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteUserId" name="userId" />
</form>

<script>
    let currentUserId = '';
    let currentDepartment = '';

    function showEditModalFromBtn(btn) {
        currentUserId = btn.dataset.userid;
        currentDepartment = btn.dataset.department;
        document.getElementById('editUserId').value = currentUserId;
        document.getElementById('editEmployeeId').value = btn.dataset.employeeid;
        document.getElementById('editEmail').value = btn.dataset.email;
        document.getElementById('editPassword').value = '';
        document.getElementById('editModal').style.display = 'flex';
    }

    function showCreateModal() {
        document.getElementById('createModal').style.display = 'flex';
    }

    function closeMainModals() {
        document.getElementById('createModal').style.display = 'none';
        document.getElementById('editModal').style.display = 'none';
    }

    // ── Save Changes Warning ──
    function showSaveWarning() {
        document.getElementById('saveDeptName').textContent = currentDepartment;
        document.getElementById('saveTargetLabel').textContent = currentDepartment;
        document.getElementById('saveConfirmInput').value = '';
        document.getElementById('confirmSaveBtn').disabled = true;
        document.getElementById('saveWarningModal').style.display = 'flex';
    }

    function closeSaveWarning() {
        document.getElementById('saveWarningModal').style.display = 'none';
    }

    function checkSaveConfirm() {
        const val = document.getElementById('saveConfirmInput').value.trim();
        document.getElementById('confirmSaveBtn').disabled = (val !== currentDepartment);
    }

    function confirmSave() {
        document.getElementById('saveWarningModal').style.display = 'none';
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('editForm').submit();
    }

    // ── Reset Password Warning ──
    function showResetWarning() {
        document.getElementById('resetDeptName').textContent = currentDepartment;
        document.getElementById('resetConfirmInput').value = '';
        document.getElementById('confirmResetBtn').disabled = true;
        document.getElementById('resetUserId').value = currentUserId;
        document.getElementById('resetWarningModal').style.display = 'flex';
    }

    function closeResetWarning() {
        document.getElementById('resetWarningModal').style.display = 'none';
    }

    function checkResetConfirm() {
        const val = document.getElementById('resetConfirmInput').value.trim();
        document.getElementById('confirmResetBtn').disabled = (val !== 'RESET PASSWORD');
    }

    function confirmReset() {
        document.getElementById('resetWarningModal').style.display = 'none';
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('resetForm').submit();
    }

    // ── Delete Account Warning ──
    function showDeleteWarning() {
        document.getElementById('deleteDeptName').textContent = currentDepartment;
        document.getElementById('deleteTargetLabel').textContent = currentDepartment;
        document.getElementById('deleteConfirmInput').value = '';
        document.getElementById('confirmDeleteBtn').disabled = true;
        document.getElementById('deleteUserId').value = currentUserId;
        document.getElementById('deleteWarningModal').style.display = 'flex';
    }

    function closeDeleteWarning() {
        document.getElementById('deleteWarningModal').style.display = 'none';
    }

    function checkDeleteConfirm() {
        const val = document.getElementById('deleteConfirmInput').value.trim();
        document.getElementById('confirmDeleteBtn').disabled = (val !== currentDepartment);
    }

    function confirmDelete() {
        document.getElementById('deleteWarningModal').style.display = 'none';
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('deleteForm').submit();
    }
</script>

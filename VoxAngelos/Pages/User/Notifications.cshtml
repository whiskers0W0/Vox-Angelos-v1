@page
@model VoxAngelos.Pages.User.NotificationsModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Notifications";
}


@section Styles {
    <link rel="stylesheet" href="~/css/citizen-notification.css" />
}

<div class="content-header">
    <h1 class="page-title">Your Concerns</h1>
</div>

<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="outbox">Outbox</button>
    <button class="tab-btn" data-view="inbox">Inbox</button>
</div>

<!-- Outbox -->
<div id="outboxView" class="view-section active-view">
    <div class="outbox-feed">
        @if (!Model.Outbox.Any())
        {
            <p class="empty-state">No concerns submitted yet.</p>
        }
        @foreach (var concern in Model.Outbox)
        {
            var statusCss = concern.Status.ToLower().Replace(" ", "-");
    
            <div class="concern-card">
                <div class="concern-status @statusCss">
                    @concern.Status
                </div>

                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div>
                            <div class="author-name">@Model.CitizenFullName</div>
                        </div>
                    </div>
                    <div class="card-date">@Model.GetTimeAgo(concern.SubmittedAt)</div>
                </div>

                <div class="card-meta">
                    <span class="meta-label">
                        Category: <span class="meta-value">@concern.Category</span>
                    </span>
                </div>

                <div class="card-body">
                    <p class="concern-excerpt">@concern.Description</p>
                </div>

                @if (concern.FirstAttachmentPath != null)
                {
                    <div class="concern-attachments">
                        <div class="concern-photo">
                            <img src="@concern.FirstAttachmentPath" alt="Concern photo" />
                        </div>
                    </div>
                }

                <div class="concern-location">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 2C8.686 2 6 4.686 6 8c0 5.25 6 13 6 13s6-7.75 6-13c0-3.314-2.686-6-6-6z" />
                        <circle cx="12" cy="8" r="2" />
                    </svg>
                    @concern.LocationName
                </div>
            </div>
        }
    </div>
</div>

<!-- Inbox -->
<div id="inboxView" class="view-section">
    <div class="inbox-feed">
        @if (!Model.Inbox.Any())
        {
            <p class="empty-state">No replies from LGU yet.</p>
        }
        @foreach (var concern in Model.Inbox)
        {
            <div class="concern-card">
                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div>
                            <div class="author-name">@Model.CitizenFullName</div>
                        </div>
                    </div>
                    <div class="card-date">@Model.GetTimeAgo(concern.SubmittedAt)</div>
                </div>

                <div class="card-meta">
                    <span class="meta-label">
                        Category: <span class="meta-value">@concern.Category</span>
                    </span>
                </div>

                <div class="inbox-reply">
                    <div class="reply-box">
                        <div class="office-info">
                            <div class="office-avatar">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                </svg>
                            </div>
                            <div class="office-name">LGU Office</div>
                        </div>
                        <p class="reply-text">@concern.LguNotes</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


@section Scripts {
    <script>
        const tabButtons = document.querySelectorAll('.tab-btn');
        const outboxView = document.getElementById('outboxView');
        const inboxView = document.getElementById('inboxView');
        const tabIndicator = document.querySelector('.tab-indicator');

        tabButtons.forEach((btn, index) => {
            btn.addEventListener('click', () => {
                tabButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                tabIndicator.style.transform = `translateX(${index * 100}%)`;

                const selectedView = btn.dataset.view;

                if (selectedView === "outbox") {
                    outboxView.classList.add("active-view");
                    inboxView.classList.remove("active-view");
                } else {
                    outboxView.classList.remove("active-view");
                    inboxView.classList.add("active-view");
                }
            });
        });

        document.querySelectorAll('.vote-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.classList.toggle('voted');
            });
        });
    </script>
}
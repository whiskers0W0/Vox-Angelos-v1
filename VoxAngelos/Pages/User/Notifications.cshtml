@page
@model VoxAngelos.Pages.User.NotificationsModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Your Concerns";
}


@section Styles {
    <link rel="stylesheet" href="~/css/citizen-notification.css" asp-append-version="true" />
}

<div class="content-header">
    <h1 class="page-title">Your Concerns</h1>
</div>

<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="outbox">My Concerns</button>
    <button class="tab-btn" data-view="inbox">LGU Responses</button>
</div>

<!-- Submitted concerns -->
<div id="outboxView" class="view-section active-view">
    <div class="outbox-feed">
        @if (!Model.Outbox.Any())
        {
            <p class="empty-state">No concerns submitted yet.</p>
        }
        @foreach (var concern in Model.Outbox)
        {
            var statusCss = concern.Status.ToLower().Replace(" ", "-");
    
            <div class="concern-card">
                <div class="concern-status @statusCss">
                    @concern.Status
                </div>

                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div>
                            <div class="author-name">@Model.CitizenFullName</div>
                        </div>
                    </div>
                    <div class="card-date">@Model.GetTimeAgo(concern.SubmittedAt)</div>
                </div>

                <div class="card-meta">
                    <span class="meta-label">
                        Category: <span class="meta-value">@concern.Category</span>
                    </span>
                </div>

                <div class="card-body">
                    <p class="concern-excerpt">@concern.Description</p>
                </div>

                @if (concern.Attachments.Any())
                {
                    <div class="concern-attachments">
                        @foreach (var attachment in concern.Attachments)
                        {
                            if (attachment.FileType == "video")
                            {
                                <video class="concern-media" controls preload="metadata">
                                    <source src="@attachment.FilePath" />
                                    Your browser does not support video playback.
                                </video>
                            }
                            else if (attachment.FileType == "document")
                            {
                                <a class="concern-document" href="@attachment.FilePath" target="_blank" rel="noopener" title="Open PDF document in a new tab">
                                    <span class="concern-document-icon" aria-hidden="true">PDF</span>
                                    <span>
                                        <strong>Attached document</strong>
                                        <small>Open PDF</small>
                                    </span>
                                </a>
                            }
                            else
                            {
                                <a class="concern-photo" href="@attachment.FilePath" target="_blank" rel="noopener" title="Open image in a new tab">
                                    <img src="@attachment.FilePath" alt="Open attached concern image" />
                                </a>
                            }
                        }
                    </div>
                }

                <div class="concern-location">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                         stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 2C8.686 2 6 4.686 6 8c0 5.25 6 13 6 13s6-7.75 6-13c0-3.314-2.686-6-6-6z" />
                        <circle cx="12" cy="8" r="2" />
                    </svg>
                    @concern.LocationName
                </div>

                <details class="concern-timeline">
                    <summary>
                        <span>View timeline</span>
                        <span class="timeline-count">@concern.Timeline.Count event@(concern.Timeline.Count == 1 ? "" : "s")</span>
                    </summary>
                    <ol class="timeline-list">
                        @foreach (var timelineEvent in concern.Timeline)
                        {
                            var timelineStatusCss = timelineEvent.Status.ToLower().Replace(" ", "-");
                            <li class="timeline-item">
                                <span class="timeline-marker @timelineStatusCss" aria-hidden="true"></span>
                                <div class="timeline-content">
                                    <div class="timeline-heading">
                                        <strong>@timelineEvent.EventType</strong>
                                        <span class="timeline-status @timelineStatusCss">@timelineEvent.Status</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(timelineEvent.Message))
                                    {
                                        <p class="timeline-message">@timelineEvent.Message</p>
                                    }
                                    <div class="timeline-meta">
                                        @(timelineEvent.ActorName ?? timelineEvent.ActorRole) · @timelineEvent.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy h:mm tt")
                                    </div>
                                </div>
                            </li>
                        }
                    </ol>
                </details>
            </div>
        }
    </div>
</div>

<!-- LGU responses and status updates -->
<div id="inboxView" class="view-section">
    <div class="inbox-feed">
        @if (!Model.Inbox.Any())
        {
            <p class="empty-state">No LGU responses or status updates yet.</p>
        }
        @foreach (var concern in Model.Inbox)
        {
            <div class="concern-card">
                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div>
                            <div class="author-name">@Model.CitizenFullName</div>
                        </div>
                    </div>
                    <div class="card-date">@Model.GetTimeAgo(concern.UpdatedAt ?? concern.SubmittedAt)</div>
                </div>

                <div class="card-meta">
                    <span class="meta-label">
                        Category: <span class="meta-value">@concern.Category</span>
                    </span>
                </div>

                <div class="inbox-reply">
                    <div class="reply-box">
                        <div class="office-info">
                            <div class="office-avatar">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                </svg>
                            </div>
                            <div class="office-name">LGU Office</div>
                        </div>
                        <p class="reply-text">
                            @(string.IsNullOrWhiteSpace(concern.LguNotes)
                                ? $"Your concern status is now {concern.Status}."
                                : concern.LguNotes)
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


@section Scripts {
    <script>
        const tabButtons = document.querySelectorAll('.tab-btn');
        const outboxView = document.getElementById('outboxView');
        const inboxView = document.getElementById('inboxView');
        const tabIndicator = document.querySelector('.tab-indicator');

        tabButtons.forEach((btn, index) => {
            btn.addEventListener('click', () => {
                tabButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                tabIndicator.style.transform = `translateX(${index * 100}%)`;

                const selectedView = btn.dataset.view;

                if (selectedView === "outbox") {
                    outboxView.classList.add("active-view");
                    inboxView.classList.remove("active-view");
                } else {
                    outboxView.classList.remove("active-view");
                    inboxView.classList.add("active-view");
                }
            });
        });

        document.querySelectorAll('.vote-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                btn.classList.toggle('voted');
            });
        });
    </script>
}

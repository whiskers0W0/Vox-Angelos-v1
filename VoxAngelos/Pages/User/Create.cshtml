@page
@model VoxAngelos.Pages.User.CreateModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Create";
}

@section Styles {
    <link rel="stylesheet" href="~/css/citizen-create.css" asp-append-version="true" />
}
<div class="content-header">
    <h1 class="page-title">Submit a Concern</h1>
</div>

<!-- Toggle Tabs -->
<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="concern">Concern</button>
    <button class="tab-btn" data-view="project">Recommendation</button>
</div>

@if (TempData["ConcernSuccess"] != null)
{
    <div class="custom-alert-container">
        <div class="neomorphic-alert success">
            <div class="alert-icon-circle">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <span class="alert-text">@TempData["ConcernSuccess"]</span>
            <button type="button" class="alert-close" onclick="this.parentElement.style.display='none';">
                &times;
            </button>
        </div>
    </div>
}

<!-- Concern Form -->
<div id="concernView" class="view-section active-view">
    <div style="display:flex; justify-content:center; width:100%;">
        <div class="concern-card">

            <form id="concernForm" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Hidden fields populated by JS -->
                <input type="hidden" id="hdnLocationName" name="LocationName" />
                <input type="hidden" id="hdnLatitude" name="Latitude" />
                <input type="hidden" id="hdnLongitude" name="Longitude" />

                <!-- User row -->
                <div class="concern-user-row">
                    <div class="concern-avatar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                    <span class="concern-username">@Model.CitizenFullName</span>
                </div>

                <!-- Description -->
                <div class="concern-form-group">
                    <label class="concern-form-label">Description:</label>
                    <div class="concern-description-guide" id="concernDescriptionGuide">
                        <p><strong>For faster routing:</strong> Include <strong>what happened</strong>, the <strong>exact location or nearby landmark</strong>, <strong>when</strong> you noticed it, and important details such as the affected area or severity. Use specific words like “pothole,” “uncollected garbage,” or “broken streetlight.”</p>
                        <p><strong>Para mas mabilis na maipadala sa tamang tanggapan:</strong> Isama ang <strong>nangyari</strong>, ang <strong>eksaktong lugar o malapit na palatandaan</strong>, <strong>kailan</strong> ito napansin, at mahahalagang detalye tulad ng apektadong bahagi o tindi ng problema. Gumamit ng tiyak na salita gaya ng “lubak,” “hindi nakolektang basura,” o “sirang poste ng ilaw.”</p>
                    </div>
                    <textarea class="concern-textarea" id="concernDescription"
                              name="Description" aria-describedby="concernDescriptionGuide"
                              placeholder="Describe your concern..."></textarea>
                </div>
                
                <span class="text-danger small" id="err-description"></span>
                <!-- Location -->
                <div class="concern-location-row">
                    <label class="concern-form-label">Location:</label>
                    <span class="concern-location-value" id="concernLocationText" aria-live="polite">No location selected</span>
                    <button class="use-map-link" id="useMapBtn" type="button" aria-label="Select the concern location on a map">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z" />
                            <circle cx="12" cy="10" r="2.5" />
                        </svg>
                        <span>Select on map</span>
                    </button>
                </div>
                
                <span class="text-danger small" id="err-location"></span>

                <!-- Attachments -->
                <div class="concern-attachment-row">
                    <label class="concern-form-label">Attachment/s:</label>
                    <button class="concern-upload-btn" type="button" id="concernUploadBtn">
                        <span class="upload-label">Upload</span>
                        <span class="upload-hint">(.jpg .png .mp4 .pdf)</span>
                    </button>
                    <input type="file" id="concernFileInput" name="Attachments"
                           style="display:none;" multiple accept="image/*,video/*,.pdf" />
                    <span class="concern-file-names" id="concernFileNames"></span>
                </div>
                <span class="text-danger small" id="err-attachment"></span>

                <!-- Submit -->
                <div class="concern-submit-row">
                    <button class="btn-submit" id="concernSaveDraftBtn" type="button" style="margin-right:8px;">Save Draft</button>
                    <button class="btn-submit" id="concernSubmitBtn" type="button">Submit</button>
                </div>
                <p id="concernDraftStatus" aria-live="polite" style="margin:8px 0 0; font-size:13px;"></p>

            </form>
        </div>
    </div>
</div>

<!-- Project Proposal Multi-Step Form -->
<div id="projectView" class="view-section">
    <div style="display:flex; justify-content:center; width:100%;">
        <div class="proposal-card">

            <div class="proposal-card-header">
                <h2>Submit a Citizen Recommendation</h2>
                <p>Vox Angelos: Make your voice heard.</p>
            </div>

            <!-- STEP 1: Project Type -->
            <div class="step-content active" id="step1">
                <div class="form-group">
                    <label class="form-label bilingual-question" for="projectJustification">
                        <span><strong>What community problem are you trying to solve?</strong> Tell us what is happening, where it occurs, who is affected, and how it affects daily life, safety, health, or the environment.</span>
                        <span>Anong problema sa komunidad ang nais ninyong maresolba? Ilarawan ang nangyayari, saan ito nagaganap, sino ang naaapektuhan, at paano nito naaapektuhan ang araw-araw na buhay, kaligtasan, kalusugan, o kapaligiran.</span>
                    </label>
                    <textarea class="form-textarea" id="projectJustification" placeholder="Example: Flooding near the public market affects commuters and vendors during heavy rain..."></textarea>
                </div>

                <p class="step-question bilingual-question">
                    <span>What type of recommendation would you like to propose?</span>
                    <span>Anong uri ng rekomendasyon ang nais ninyong ihain?</span>
                </p>
                <div class="category-grid">
                    <button class="category-btn" type="button" data-value="Infrastructure & Public Works">
                        <span class="category-name">Infrastructure & Public Works</span>
                        <span class="category-example">Example: roads, drainage, sidewalks, or streetlights</span>
                    </button>
                    <button class="category-btn" type="button" data-value="Environment & Sanitation">
                        <span class="category-name">Environment & Sanitation</span>
                        <span class="category-example">Example: garbage collection, waste bins, flooding, or pollution</span>
                    </button>
                    <button class="category-btn" type="button" data-value="Community & Social Welfare">
                        <span class="category-name">Community & Social Welfare</span>
                        <span class="category-example">Example: livelihood, youth activities, or family assistance</span>
                    </button>
                    <button class="category-btn" type="button" data-value="Public Safety, Traffic & Transport">
                        <span class="category-name">Public Safety, Traffic & Transport</span>
                        <span class="category-example">Example: crosswalks, traffic flow, road safety, or lighting</span>
                    </button>
                    <button class="category-btn" type="button" data-value="Urban Planning & Public Spaces">
                        <span class="category-name">Urban Planning & Public Spaces</span>
                        <span class="category-example">Example: parks, public spaces, zoning, or city planning</span>
                    </button>
                    <button class="category-btn" type="button" data-value="Senior Citizen Support">
                        <span class="category-name">Senior Citizen Support</span>
                        <span class="category-example">Example: senior programs, facilities, or accessibility</span>
                    </button>
                    <button class="category-btn" type="button" data-value="PWD Accessibility & Services">
                        <span class="category-name">PWD Accessibility & Services</span>
                        <span class="category-example">Example: ramps, accessible facilities, or disability support</span>
                    </button>
                    <button class="category-btn category-unsure" type="button" data-value="Unsure">
                        <span class="category-name">Unsure</span>
                        <span class="category-example">Describe your recommendation and we will classify it for you.</span>
                    </button>
                </div>
            </div>

            <!-- STEP 2: Project Details -->
            <div class="step-content" id="step2">
                <div class="form-group">
                    <label class="form-label bilingual-question" for="projectTitle">
                        <span><strong>What is a clear title for your recommendation?</strong> Keep it short and specific.</span>
                        <span><strong>Ano ang malinaw na pamagat ng inyong rekomendasyon?</strong> Panatilihin itong maikli at tiyak.</span>
                    </label>
                    <input type="text" class="form-input" id="projectTitle" placeholder="Example: Improve drainage near the public market" />
                </div>
                <div class="form-group">
                    <label class="form-label bilingual-question" for="projectLocation">
                        <span><strong>Where should this recommendation be implemented?</strong> Include the barangay, street, facility, or nearby landmark.</span>
                        <span><strong>Saan dapat ipatupad ang rekomendasyong ito?</strong> Isama ang barangay, kalye, pasilidad, o malapit na palatandaan.</span>
                    </label>
                    <input type="text" class="form-input" id="projectLocation" placeholder="Example: Sto. Rosario, near the public market" />
                </div>
                <div class="form-group">
                    <label class="form-label bilingual-question" for="projectDescription">
                        <span><strong>What should the city do, and what improvement do you expect?</strong> Mention the key activities, facilities, or services that should be included.</span>
                        <span><strong>Ano ang iminumungkahi ninyong gawin ng lungsod, at anong pagbabago ang inaasahan ninyo?</strong> Banggitin ang mahahalagang gawain, pasilidad, o serbisyong dapat isama.</span>
                    </label>
                    <textarea class="form-textarea" id="projectDescription" placeholder="Example: Build covered drainage and add waste bins to reduce flooding and improve sanitation..."></textarea>
                </div>
            </div>

            <!-- STEP 3: More Details -->
            <div class="step-content" id="step3">
                <p class="step-question bilingual-question">
                    <span><strong>Who will benefit most from this recommendation?</strong> Select all groups that may benefit.</span>
                    <span><strong>Sino ang pangunahing makikinabang sa rekomendasyong ito?</strong> Piliin ang lahat ng grupong maaaring makinabang.</span>
                </p>

                <div class="form-group">
                    <label class="form-label left">Beneficiary groups / Mga grupong makikinabang</label>
                    <div class="checkbox-group">
                        <label class="checkbox-label"><input type="checkbox" name="beneficiary" value="Local residents" /> Local residents</label>
                        <label class="checkbox-label"><input type="checkbox" name="beneficiary" value="Students" /> Students</label>
                        <label class="checkbox-label"><input type="checkbox" name="beneficiary" value="Businesses" /> Businesses</label>
                        <label class="checkbox-label"><input type="checkbox" name="beneficiary" value="Senior citizens" /> Senior citizens</label>
                        <label class="checkbox-label"><input type="checkbox" name="beneficiary" value="Entire community" /> Entire community</label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label left bilingual-question" for="peopleAffected">
                        <span><strong>Approximately how many people may benefit?</strong> Give your best estimate.</span>
                        <span><strong>Humigit-kumulang ilang tao ang maaaring makinabang?</strong> Ibigay ang pinakamalapit ninyong tantiya.</span>
                    </label>
                    <input type="number" class="form-input" id="peopleAffected" placeholder="e.g. 500" />
                </div>

                <div class="anonymous-choice">
                    <input type="checkbox" id="recIsAnonymous" />
                    <label for="recIsAnonymous">
                        <span><strong>Post anonymously on Discover</strong> — other citizens will see “Anonymous Citizen” instead of your name.</span>
                        <span>Manatiling anonymous sa Discover — makikita ng ibang mamamayan ang “Anonymous Citizen” sa halip na ang inyong pangalan.</span>
                    </label>
                </div>
                <p class="anonymous-note">Authorized LGU staff can still view your identity when reviewing or following up on the recommendation.</p>

                <div class="form-group">
                    <label class="form-label left bilingual-question">
                        <span><strong>Do you have photos, examples, or documents that support your recommendation?</strong> This is optional.</span>
                        <span><strong>Mayroon ba kayong larawan, halimbawa, o dokumentong sumusuporta sa inyong rekomendasyon?</strong> Opsyonal ito.</span>
                    </label>
                    <button class="upload-btn" type="button" id="uploadBtn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                            <polyline points="17 8 12 3 7 8" />
                            <line x1="12" y1="3" x2="12" y2="15" />
                        </svg>
                        Upload Photo or Document
                    </button>
                    <input type="file" id="fileInput"
                           style="display:none;"
                           multiple
                           accept="image/*,video/*,.pdf,.doc,.docx" />
                    <p class="file-name-label" id="fileLabel"></p>
                </div>
            </div>

            <!-- STEP 4: Review -->
            <div class="step-content" id="step4">
                <p class="review-section-title">Review Your Recommendation</p>
                <div class="review-box" id="reviewBox">
                    <div><strong>Justification:</strong> <span id="r-justification"></span></div>
                    <div><strong>Recommendation Type:</strong> <span id="r-type"></span></div>
                    <div><strong>Recommendation Title:</strong> <span id="r-title"></span></div>
                    <div><strong>Location:</strong> <span id="r-location"></span></div>
                    <div><strong>Description:</strong> <span id="r-description"></span></div>
                    <br>
                    <div><strong>Beneficiaries:</strong> <span id="r-beneficiaries"></span></div>
                    <div><strong>Est. people affected:</strong> <span id="r-people"></span></div>
                    <div><strong>Privacy:</strong> <span id="r-privacy"></span></div>
                    <div><strong>Attachments:</strong> <div id="r-attachments" style="display:flex;flex-wrap:wrap;margin-top:6px;"></div></div>
                </div>
            </div>

            <!-- Success State -->
            <div class="success-state" id="successState">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                </div>
                <h3>Recommendation Submitted!</h3>
                <p>Your proposed recommendation has been received.<br>We'll review it and get back to you.</p>
                <button class="btn-new" id="btnNewProposal">Submit Another</button>
            </div>

            <!-- Footer -->
            <div class="step-footer" id="stepFooter">
                <span class="step-counter" id="stepCounter">Step 1 of 4</span>
                <div class="footer-actions">
                    <button class="btn-back" id="btnSaveDraft" type="button">Save Draft</button>
                    <button class="btn-back" id="btnBack" style="display:none;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                        Back
                    </button>
                    <button class="btn-next" id="btnNext">
                        Next
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>
                </div>
                <p id="recommendationStatus" aria-live="polite" style="margin:8px 0 0; font-size:13px;"></p>
            </div>

        </div>
    </div>
</div>

<!-- Map Modal -->
<div class="map-modal-overlay" id="mapModalOverlay">
    <div class="map-modal">
        <div style="padding: 8px 12px; display:flex; gap:6px;">
            <input id="mapSearchBox" type="text" placeholder="Search location in Angeles City..."
                   style="flex:1; padding:8px; border:1px solid #ccc; border-radius:6px; font-size:13px;" />
            <button id="mapSearchBtn" type="button"
                    style="padding:8px 14px; background:#2B45B0; color:white; border:none; border-radius:6px; cursor:pointer;">
                Search
            </button>
        </div>
        <div id="googleMap" style="width:100%; height:350px;"></div>
        <div class="map-modal-footer">
            <span class="map-coord-label">Location/Coordinate:</span>
            <span class="map-coord-value" id="mapCoordDisplay"></span>
            <button class="btn-submit" id="mapConfirmBtn" type="button">Confirm</button>
        </div>
    </div>
</div>

<!-- AI Category Confirmation Modal -->
<div class="map-modal-overlay" id="categoryModalOverlay">
    <div class="map-modal" style="max-width:420px; padding: 24px;">
        <div style="text-align:center; margin-bottom:16px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2B45B0" stroke-width="2"
                 style="width:48px;height:48px;margin-bottom:8px;">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <h3 style="margin:0;font-size:18px;font-weight:700;color:#1a1a2e;">Concern Categorized</h3>
        </div>
        <p style="text-align:center;color:#555;margin-bottom:8px;">
            Our AI has categorized your concern as:
        </p>
        <div style="background:#f0f4ff;border-radius:10px;padding:14px;margin-bottom:12px;text-align:center;">
            <strong id="modalCategory" style="color:#2B45B0;font-size:16px;"></strong>
        </div>
        <p style="text-align:center;color:#555;margin-bottom:6px;">
            This will be sent to:
        </p>
        <div style="background:#f0f4ff;border-radius:10px;padding:14px;margin-bottom:20px;text-align:center;">
            <strong id="modalOffice" style="color:#1a1a2e;"></strong><br>
            <span id="modalEmail" style="color:#2B45B0;font-size:13px;"></span>
        </div>
        <p style="text-align:center;color:#888;font-size:13px;margin-bottom:20px;">
            Is this correct? You can confirm or cancel to edit your description.
        </p>
        <div style="display:flex;gap:10px;justify-content:center;">
            <button id="categoryConfirmBtn" class="btn-submit"
                    style="padding:10px 28px;">
                ✓ Confirm & Submit
            </button>
            <button id="categoryCancelBtn"
                    style="padding:10px 20px;border:1px solid #ccc;border-radius:8px;background:white;cursor:pointer;font-size:14px;">
                Cancel
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const savedConcernDraft = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
        {
            HasDraft = Model.SavedConcernDraft != null,
            Description = Model.SavedConcernDraft?.Description,
            LocationName = Model.SavedConcernDraft?.LocationName,
            Latitude = Model.SavedConcernDraft?.Latitude,
            Longitude = Model.SavedConcernDraft?.Longitude
        }));

        const savedRecommendationDraft = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
        {
            HasDraft = Model.SavedRecommendationDraft != null,
            Justification = Model.SavedRecommendationDraft?.Justification,
            Category = Model.SavedRecommendationDraft?.Category,
            Title = Model.SavedRecommendationDraft?.Title,
            Location = Model.SavedRecommendationDraft?.Location,
            Description = Model.SavedRecommendationDraft?.Description,
            Beneficiaries = Model.SavedRecommendationDraft?.Beneficiaries,
            EstimatedPeopleAffected = Model.SavedRecommendationDraft?.EstimatedPeopleAffected,
            IsAnonymous = Model.SavedRecommendationDraft?.IsAnonymous
        }));

        /* ── Tab switching ──────────────────────────── */
        const tabButtons = document.querySelectorAll('.tab-btn');
        const concernView = document.getElementById('concernView');
        const projectView = document.getElementById('projectView');
        const tabIndicator = document.querySelector('.tab-indicator');
        const pageTitle = document.querySelector('.page-title');

        tabButtons.forEach((btn, index) => {
            btn.addEventListener('click', () => {
                tabButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                tabIndicator.style.transform = `translateX(${index * 100}%)`;
                const selectedView = btn.dataset.view;
                if (selectedView === "concern") {
                    concernView.classList.add("active-view");
                    projectView.classList.remove("active-view");
                    pageTitle.textContent = "Submit a Concern";
                } else {
                    concernView.classList.remove("active-view");
                    projectView.classList.add("active-view");
                    pageTitle.textContent = "Submit a Recommendation";
                }
            });
        });
                     
               /* ── Multi-step form ────────────────────────── */
        let currentStep = 1;
        const totalSteps = 4;
        let selectedCategory = '';

        const steps = document.querySelectorAll('.step-content');
        const btnBack = document.getElementById('btnBack');
        const btnNext = document.getElementById('btnNext');
        const btnSaveDraft = document.getElementById('btnSaveDraft');
        const stepCounter = document.getElementById('stepCounter');
        const stepFooter = document.getElementById('stepFooter');
        const successState = document.getElementById('successState');
        const recommendationStatus = document.getElementById('recommendationStatus');

        document.querySelectorAll('.category-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                // Remove 'selected' from all buttons and add to the clicked one
                document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
        
                selectedCategory = btn.dataset.value;
            });
        });
            
        // File upload
        const uploadBtn = document.getElementById('uploadBtn');
        const fileInput = document.getElementById('fileInput');
        const fileLabel = document.getElementById('fileLabel');

        uploadBtn.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', () => {
            const files = Array.from(fileInput.files);
            fileLabel.textContent = files.length ? files.map(f => f.name).join(', ') : '';
        });

        function renderReview() {
            document.getElementById('r-justification').textContent = document.getElementById('projectJustification').value || '—';
            document.getElementById('r-type').textContent = selectedCategory || '—';
            document.getElementById('r-title').textContent = document.getElementById('projectTitle').value || '—';
            document.getElementById('r-location').textContent = document.getElementById('projectLocation').value || '—';
            document.getElementById('r-description').textContent = document.getElementById('projectDescription').value || '—';

            const checked = Array.from(document.querySelectorAll('input[name="beneficiary"]:checked')).map(c => c.value);
            document.getElementById('r-beneficiaries').textContent = checked.length ? checked.join(', ') : '—';
    
            const people = document.getElementById('peopleAffected').value;
            document.getElementById('r-people').textContent = people || '—';
            document.getElementById('r-privacy').textContent = document.getElementById('recIsAnonymous').checked
                ? 'Anonymous on Discover'
                : 'Show my name on Discover';
    
            const files = Array.from(fileInput.files);
            const attachmentContainer = document.getElementById('r-attachments');
            attachmentContainer.innerHTML = '';

            if (files.length === 0) {
                attachmentContainer.textContent = 'None';
            } else {
                files.forEach(file => {
                    if (file.type.startsWith('image/')) {
                        const img = document.createElement('img');
                        img.style.cssText = 'width:80px;height:80px;object-fit:cover;border-radius:8px;margin:4px;';
                        img.src = URL.createObjectURL(file);
                        attachmentContainer.appendChild(img);
                    } else {
                        const span = document.createElement('span');
                        span.style.cssText = 'display:inline-block;padding:4px 8px;background:#f0f0f0;border-radius:6px;font-size:12px;margin:4px;';
                        span.textContent = file.name;
                        attachmentContainer.appendChild(span);
                    }
                });
            }
        }

        function goToStep(step) {
            steps.forEach(s => s.classList.remove('active'));
            document.getElementById('step' + step).classList.add('active');
            stepCounter.textContent = `Step ${step} of ${totalSteps}`;
            btnBack.style.display = step > 1 ? 'flex' : 'none';

            if (step === totalSteps) {
                renderReview();
                btnNext.innerHTML = 'Submit';
                btnNext.className = 'btn-submit';
            } else {
                btnNext.innerHTML = 'Next <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><polyline points="9 18 15 12 9 6"/></svg>';
                btnNext.className = 'btn-next';
            }
        }

        function buildRecommendationFormData(includeAttachments) {
            const formData = new FormData();
            formData.append('RecJustification', document.getElementById('projectJustification').value);
            formData.append('RecCategory', selectedCategory);
            formData.append('RecTitle', document.getElementById('projectTitle').value);
            formData.append('RecLocation', document.getElementById('projectLocation').value);
            formData.append('RecDescription', document.getElementById('projectDescription').value);

            const checked = Array.from(document.querySelectorAll('input[name="beneficiary"]:checked'))
                .map(c => c.value).join(', ');
            formData.append('RecBeneficiaries', checked);
            formData.append('RecPeopleAffected', document.getElementById('peopleAffected').value);
            formData.append('RecIsAnonymous', document.getElementById('recIsAnonymous').checked);

            if (includeAttachments) {
                const files = fileInput.files;
                for (let i = 0; i < files.length; i++) {
                    formData.append('RecAttachments', files[i]);
                }
            }

            formData.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]').value);
            return formData;
        }

        async function readRecommendationResponse(response) {
            const data = await response.json().catch(() => null);
            if (!response.ok || !data?.success) {
                throw new Error(data?.message || data?.error || `Server returned ${response.status}. Please try again.`);
            }

            return data;
        }

        btnSaveDraft.addEventListener('click', async () => {
            recommendationStatus.textContent = '';
            btnSaveDraft.disabled = true;
            btnSaveDraft.textContent = 'Saving...';

            try {
                const response = await fetch('?handler=SaveRecommendationDraft', {
                    method: 'POST',
                    body: buildRecommendationFormData(false)
                });
                const data = await readRecommendationResponse(response);
                recommendationStatus.textContent = `${data.message} Attachments will be uploaded when you submit.`;
            } catch (error) {
                recommendationStatus.textContent = error.message;
                console.error('Draft save error:', error);
            } finally {
                btnSaveDraft.disabled = false;
                btnSaveDraft.textContent = 'Save Draft';
            }
        });

                btnNext.addEventListener('click', () => {
            if (currentStep < totalSteps) {
                // Run validation for the current step
                if (validateStep(currentStep)) {
                    currentStep++;
                    goToStep(currentStep);
                }
                } else {
                const formData = buildRecommendationFormData(true);

                fetch('?handler=Recommendation', {
                    method: 'POST',
                    body: formData
                })
                    .then(readRecommendationResponse)
                    .then(data => {
                    if (data.success) {
                        stepFooter.style.display = 'none';
                        steps.forEach(s => s.classList.remove('active'));
                        successState.classList.add('active');
                    }
                })
                .catch(err => {
                    recommendationStatus.textContent = err.message;
                    console.error('Submission error:', err);
                });
            }
            });

        function validateStep(step) {
            let isValid = true;

            // Helper to highlight invalid fields
            const invalidate = (el) => {
                el.classList.add('input-error');
                isValid = false;
                // Optional: Add a shake effect or specific error message here
            };

            // Reset previous errors
            document.querySelectorAll('.input-error').forEach(el => el.classList.remove('input-error'));

            if (step === 1) {
                // Validate Justification - NEWLY ADDED
                const justification = document.getElementById('projectJustification');
                if (!justification.value.trim()) {
                    invalidate(justification);
                }

                // Validate Category Selection
                if (!selectedCategory) {
                    document.querySelector('.category-grid').classList.add('input-error');
                    isValid = false;
                }
            }
            else if (step === 2) {
                // Validate Title, Location, and Description
                const title = document.getElementById('projectTitle');
                const loc = document.getElementById('projectLocation');
                const desc = document.getElementById('projectDescription');

                if (!title.value.trim()) invalidate(title);
                if (!loc.value.trim()) invalidate(loc);
                if (!desc.value.trim()) invalidate(desc);
            }
            else if (step === 3) {
                // Validate Beneficiaries (at least one checked)
                const checked = document.querySelectorAll('input[name="beneficiary"]:checked');
                if (checked.length === 0) {
                    document.querySelector('.checkbox-group').classList.add('input-error');
                    isValid = false;
                }
                // Validate People Affected
                const people = document.getElementById('peopleAffected');
                if (!people.value || people.value <= 0) invalidate(people);
            }

            if (!isValid) {
                console.log("Validation failed for step " + step);
            }
    
            return isValid;
        }

        // Clear error styling when user starts typing/clicking
        document.addEventListener('input', (e) => {
            if (e.target.classList.contains('form-input') || e.target.classList.contains('form-textarea')) {
                e.target.classList.remove('input-error');
            }
        });

        btnBack.addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep--;
                goToStep(currentStep);
                stepFooter.style.display = 'flex';
            }
        });

        document.getElementById('btnNewProposal').addEventListener('click', () => {
            currentStep = 1;
            selectedCategory = '';
            document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('selected'));
            document.getElementById('projectJustification').value = '';
            document.getElementById('projectTitle').value = '';
            document.getElementById('projectLocation').value = '';
            document.getElementById('projectDescription').value = '';
            document.querySelectorAll('input[name="beneficiary"]').forEach(c => c.checked = false);
            document.getElementById('peopleAffected').value = '';
            document.getElementById('recIsAnonymous').checked = false;
            fileLabel.textContent = '';
            successState.classList.remove('active');
            stepFooter.style.display = 'flex';
            goToStep(1);
        });

        function restoreSavedRecommendationDraft() {
            if (!savedRecommendationDraft.HasDraft) return;

            document.getElementById('projectJustification').value = savedRecommendationDraft.Justification || '';
            document.getElementById('projectTitle').value = savedRecommendationDraft.Title || '';
            document.getElementById('projectLocation').value = savedRecommendationDraft.Location || '';
            document.getElementById('projectDescription').value = savedRecommendationDraft.Description || '';
            document.getElementById('peopleAffected').value = savedRecommendationDraft.EstimatedPeopleAffected || '';
            document.getElementById('recIsAnonymous').checked = savedRecommendationDraft.IsAnonymous === true;

            const savedBeneficiaries = (savedRecommendationDraft.Beneficiaries || '')
                .split(',')
                .map(value => value.trim());
            document.querySelectorAll('input[name="beneficiary"]').forEach(checkbox => {
                checkbox.checked = savedBeneficiaries.includes(checkbox.value);
            });

            const categoryButton = Array.from(document.querySelectorAll('.category-btn'))
                .find(button => button.dataset.value === savedRecommendationDraft.Category);
            if (categoryButton) {
                selectedCategory = savedRecommendationDraft.Category;
                categoryButton.classList.add('selected');
            } else if (savedRecommendationDraft.Category) {
                selectedCategory = 'Unsure';
                document.querySelector('.category-btn[data-value="Unsure"]').classList.add('selected');
            }

            if (!savedConcernDraft.HasDraft) {
                tabButtons.forEach(button => {
                    button.classList.toggle('active', button.dataset.view === 'project');
                });
                concernView.classList.remove('active-view');
                projectView.classList.add('active-view');
                tabIndicator.style.transform = 'translateX(100%)';
                pageTitle.textContent = 'Continue Your Recommendation Draft';
            }
            recommendationStatus.textContent = 'Your saved draft has been restored. Attachments upload when you submit.';
        }

        restoreSavedRecommendationDraft();
        goToStep(1);

               /* ── Concern form ───────────────────────────── */
        const useMapBtn = document.getElementById('useMapBtn');
        const mapModalOverlay = document.getElementById('mapModalOverlay');
        const mapConfirmBtn = document.getElementById('mapConfirmBtn');
        const concernLocationText = document.getElementById('concernLocationText');
        const mapCoordDisplay = document.getElementById('mapCoordDisplay');

        let selectedLat = null;
        let selectedLng = null;
        let selectedAddress = '';
        let map, marker, autocompleteEl;


        useMapBtn.addEventListener('click', () => {
            mapModalOverlay.classList.add('active');
            if (!map) {
                initMap();
            }
        });

        function initMap() {
            const defaultCenter = { lat: 15.1450, lng: 120.5887 };
            const initialCenter = selectedLat !== null && selectedLng !== null
                ? { lat: selectedLat, lng: selectedLng }
                : defaultCenter;

            // Angeles City bounds
            const angelsesBounds = new google.maps.LatLngBounds(
                new google.maps.LatLng(15.1000, 120.5400), // SW corner
                new google.maps.LatLng(15.1900, 120.6400)  // NE corner
            );

            map = new google.maps.Map(document.getElementById('googleMap'), {
                center: initialCenter,
                zoom: 14,
                restriction: {
                    latLngBounds: angelsesBounds,
                    strictBounds: true  // hard lock — cannot pan outside
                }
            });

            marker = new google.maps.Marker({
                position: initialCenter,
                map: map,
                draggable: true
            });

            // Click on map to move marker
            map.addListener('click', (e) => {
                marker.setPosition(e.latLng);
                selectedLat = e.latLng.lat();
                selectedLng = e.latLng.lng();
                reverseGeocode(selectedLat, selectedLng);
            });

            // Drag marker
            marker.addListener('dragend', (e) => {
                selectedLat = e.latLng.lat();
                selectedLng = e.latLng.lng();
                reverseGeocode(selectedLat, selectedLng);
            });

            // Set initial values when there is no saved concern location.
            if (selectedLat === null || selectedLng === null) {
                selectedLat = defaultCenter.lat;
                selectedLng = defaultCenter.lng;
                reverseGeocode(selectedLat, selectedLng);
            } else {
                mapCoordDisplay.textContent = selectedAddress;
            }

            // Search restricted to Angeles City
            const searchInput = document.getElementById('mapSearchBox');
            const searchBtn = document.getElementById('mapSearchBtn');

            function searchLocation() {
                const query = searchInput.value.trim();
                if (!query) return;

                const geocoder = new google.maps.Geocoder();
                geocoder.geocode({
                    address: query + ', Angeles City, Pampanga, Philippines',
                    bounds: angelsesBounds
                }, (results, status) => {
                    if (status === 'OK' && results[0]) {
                        const latLng = results[0].geometry.location;

                        // Validate result is within Angeles City bounds
                        if (!angelsesBounds.contains(latLng)) {
                            alert('Location is outside Angeles City. Please pin a location within Angeles City, Pampanga.');
                            return;
                        }

                        map.panTo(latLng);
                        map.setZoom(16);
                        marker.setPosition(latLng);

                        selectedLat = latLng.lat();
                        selectedLng = latLng.lng();
                        selectedAddress = results[0].formatted_address;
                        mapCoordDisplay.textContent = selectedAddress;
                    } else {
                        alert('Location not found. Try a more specific address in Angeles City.');
                    }
                });
            }

            searchBtn.addEventListener('click', searchLocation);
            searchInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchLocation();
                }
            });
        }

        function reverseGeocode(lat, lng) {
            const geocoder = new google.maps.Geocoder();
            geocoder.geocode({ location: { lat, lng } }, (results, status) => {
                if (status === 'OK' && results[0]) {
                    selectedAddress = results[0].formatted_address;
                    mapCoordDisplay.textContent = selectedAddress;
                } else {
                    selectedAddress = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
                    mapCoordDisplay.textContent = selectedAddress;
                }
            });
        }

        mapConfirmBtn.addEventListener('click', () => {
            if (selectedLat && selectedLng) {
                concernLocationText.textContent = selectedAddress;
                document.getElementById('hdnLocationName').value = selectedAddress;
                document.getElementById('hdnLatitude').value = selectedLat;
                document.getElementById('hdnLongitude').value = selectedLng;
            }
            mapModalOverlay.classList.remove('active');
        });

        mapModalOverlay.addEventListener('click', (e) => {
            if (e.target === mapModalOverlay) mapModalOverlay.classList.remove('active');
        });

        // Concern file upload
        const concernUploadBtn = document.getElementById('concernUploadBtn');
        const concernFileInput = document.getElementById('concernFileInput');
        const concernFileNames = document.getElementById('concernFileNames');
        const concernSaveDraftBtn = document.getElementById('concernSaveDraftBtn');
        const concernDraftStatus = document.getElementById('concernDraftStatus');

        concernUploadBtn.addEventListener('click', () => concernFileInput.click());
        concernFileInput.addEventListener('change', () => {
            const files = Array.from(concernFileInput.files);
            concernFileNames.textContent = files.length ? files.map(f => f.name).join(', ') : '';
        });

        function buildConcernDraftFormData() {
            const formData = new FormData();
            formData.append('Description', document.getElementById('concernDescription').value);
            formData.append('LocationName', document.getElementById('hdnLocationName').value);
            formData.append('Latitude', document.getElementById('hdnLatitude').value);
            formData.append('Longitude', document.getElementById('hdnLongitude').value);
            formData.append('__RequestVerificationToken',
                document.querySelector('input[name="__RequestVerificationToken"]').value);
            return formData;
        }

        concernSaveDraftBtn.addEventListener('click', async () => {
            concernDraftStatus.textContent = '';
            concernSaveDraftBtn.disabled = true;
            concernSaveDraftBtn.textContent = 'Saving...';

            try {
                const response = await fetch('?handler=SaveConcernDraft', {
                    method: 'POST',
                    body: buildConcernDraftFormData()
                });
                const data = await response.json().catch(() => null);
                if (!response.ok || !data?.success) {
                    throw new Error(data?.message || data?.error || `Server returned ${response.status}. Please try again.`);
                }

                concernDraftStatus.textContent = `${data.message} Attachments will be uploaded when you submit.`;
            } catch (error) {
                concernDraftStatus.textContent = error.message;
                console.error('Concern draft save error:', error);
            } finally {
                concernSaveDraftBtn.disabled = false;
                concernSaveDraftBtn.textContent = 'Save Draft';
            }
        });

        function restoreSavedConcernDraft() {
            if (!savedConcernDraft.HasDraft) return;

            document.getElementById('concernDescription').value = savedConcernDraft.Description || '';
            document.getElementById('hdnLocationName').value = savedConcernDraft.LocationName || '';
            document.getElementById('hdnLatitude').value = savedConcernDraft.Latitude ?? '';
            document.getElementById('hdnLongitude').value = savedConcernDraft.Longitude ?? '';

            if (savedConcernDraft.LocationName) {
                selectedAddress = savedConcernDraft.LocationName;
                concernLocationText.textContent = savedConcernDraft.LocationName;
            }
            if (savedConcernDraft.Latitude != null && savedConcernDraft.Longitude != null) {
                selectedLat = savedConcernDraft.Latitude;
                selectedLng = savedConcernDraft.Longitude;
            }

            pageTitle.textContent = 'Continue Your Concern Draft';
            concernDraftStatus.textContent = 'Your saved draft has been restored. Attachments upload when you submit.';
        }

        restoreSavedConcernDraft();

        // Concern submit
                // Hidden fields for confirmed category
        let confirmedCategory = '';
        let confirmedOffice = '';

        // Concern submit — Step 1: validate then classify
        document.getElementById('concernSubmitBtn').addEventListener('click', async () => {
            let valid = true;

            document.getElementById('err-description').textContent = '';
            document.getElementById('err-location').textContent = '';
            document.getElementById('err-attachment').textContent = '';

            const desc = document.getElementById('concernDescription').value.trim();
            if (!desc) {
                document.getElementById('err-description').textContent = 'Could you describe the concern? Every detail helps the city respond faster.';
                valid = false;
            }

            const location = document.getElementById('hdnLocationName').value.trim();
            if (!location) {
                document.getElementById('err-location').textContent = 'We need to know where this is happening. Please drop a pin on the map.';
                valid = false;
            }

            const files = document.getElementById('concernFileInput').files;
            if (!files || files.length === 0) {
                document.getElementById('err-attachment').textContent = 'A photo or video helps us verify the situation. Please attach at least one.';
                valid = false;
            }

            if (!valid) return;

            // Show loading state
            const submitBtn = document.getElementById('concernSubmitBtn');
            submitBtn.textContent = 'Analyzing...';
            submitBtn.disabled = true;

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch('?handler=Classify', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ description: desc })
                });

                const result = await response.json();

                if (result.success) {
                    confirmedCategory = result.category;
                    confirmedOffice = result.office;

                    // Show confirmation popup
                    document.getElementById('modalCategory').textContent = result.category;
                    document.getElementById('modalOffice').textContent = result.office;
                    document.getElementById('modalEmail').textContent = result.email;
                    document.getElementById('categoryModalOverlay').classList.add('active');
                } else {
                    alert('Could not classify concern. Please try again.');
                }
            } catch (e) {
                alert('Error connecting to AI service. Please try again.');
            } finally {
                submitBtn.textContent = 'Submit';
                submitBtn.disabled = false;
            }
        });

        // Step 2: Citizen confirms — add hidden fields and submit form
        document.getElementById('categoryConfirmBtn').addEventListener('click', () => {
            const form = document.getElementById('concernForm');

            // Add hidden fields for confirmed category/office
            let catField = document.getElementById('ConfirmedCategory');
            if (!catField) {
                catField = document.createElement('input');
                catField.type = 'hidden';
                catField.id = 'ConfirmedCategory';
                catField.name = 'ConfirmedCategory';
                form.appendChild(catField);
            }
            catField.value = confirmedCategory;

            let officeField = document.getElementById('ConfirmedOffice');
            if (!officeField) {
                officeField = document.createElement('input');
                officeField.type = 'hidden';
                officeField.id = 'ConfirmedOffice';
                officeField.name = 'ConfirmedOffice';
                form.appendChild(officeField);
            }
            officeField.value = confirmedOffice;

            document.getElementById('categoryModalOverlay').classList.remove('active');
            form.submit();
        });

        document.getElementById('categoryCancelBtn').addEventListener('click', () => {
            document.getElementById('categoryModalOverlay').classList.remove('active');
        });
    </script>
    <script src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&libraries=places&v=beta&callback=initMap" async defer></script>
   
}

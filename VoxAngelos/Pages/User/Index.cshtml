@page
@model VoxAngelos.Pages.User.IndexModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Discover";
}

@section Styles {
    <link rel="stylesheet" href="~/css/citizen-discover.css" asp-append-version="true" />
}

<div class="content-header">
    <h1 class="page-title">Discover</h1>

    <div class="header-right">

        <select class="filter-select" id="officeFilter" aria-label="Filter by LGU office">
            <option value="">All Offices</option>

            @foreach (var office in VoxAngelos.Pages.User.IndexModel.Offices)
            {
                <option value="@office.Code">@office.Name</option>
            }
        </select>

        <select class="filter-select" id="periodFilter" aria-label="Filter by publication date">
            <option value="">All Dates</option>
            <option value="day">Today</option>
            <option value="week">This Week</option>
            <option value="month">This Month</option>
            <option value="year">This Year</option>
        </select>

        <select class="filter-select" id="dateSort" aria-label="Sort by date">
            <option value="desc">Newest First</option>
            <option value="asc">Oldest First</option>
        </select>

        <div class="search-box">
            <input type="text" placeholder="Search" class="search-input" id="searchInput" />
            <button class="search-btn" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </button>
        </div>

    </div>
</div>
@* to prove the request is coming from your own page and not from a malicious site *@
@Html.AntiForgeryToken()

<!-- Toggle Tabs -->
<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="proposals">Citizen Recommendations</button>
    <button class="tab-btn" data-view="leaderboard">Top Rated</button>
</div>

<!-- Proposals View -->
<div id="proposalsView" class="view-section active-view">
    <div class="proposals-feed" id="proposalsFeed">

        @if (!Model.Recommendations.Any())
        {
            <div style="text-align:center;padding:60px;color:#888;">
                <p>No approved recommendations yet.</p>
            </div>
        }

        @foreach (var rec in Model.Recommendations)
        {
            <div class="proposal-card" data-rec-id="@rec.Id" data-title="@rec.Title.ToLower()" data-description="@rec.Description.ToLower()" data-category="@rec.Category.ToLowerInvariant()" data-office="@rec.AssignedOffice" data-date="@rec.ApprovedAt.ToString("yyyy-MM-dd")">
                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div class="author-name">@rec.CitizenName</div>
                    </div>
                    <div class="card-date">@rec.ApprovedAt.ToString("MM/dd/yy")</div>
                </div>

                <div class="card-meta">
                    @if (!string.IsNullOrEmpty(rec.AssignedOffice))
                    {
                        <span class="meta-label">Office: <span class="meta-value">@rec.AssignedOffice</span></span>
                    }
                </div>

                <div class="card-body">
                    <h3 class="proposal-title">Citizen Recommendation: @rec.Title</h3>
                    <p class="proposal-excerpt">@rec.Description</p>
                </div>

                @if (rec.AttachmentPaths.Any())
                {
                    <div class="attachments">
                        @{
                            var maxShow = Math.Min(2, rec.AttachmentPaths.Count);
                            var extra = rec.AttachmentPaths.Count - maxShow;
                        }
                        @for (int i = 0; i < maxShow; i++)
                        {
                            var path = rec.AttachmentPaths[i];
                            var type = rec.AttachmentTypes[i];
                            <div class="attachment-thumb">
                                @if (type == "image" || type.StartsWith("image/"))
                                {
                                    <img src="@path" alt="attachment" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />
                                }
                                else if (type == "video" || type.StartsWith("video/"))
                                {
                                    <video controls preload="metadata" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
                                        <source src="@path" />
                                        Your browser does not support video playback.
                                    </video>
                                }
                                else
                                {
                                    <div class="thumb-placeholder">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14,2 14,8 20,8" />
                                        </svg>
                                    </div>
                                }
                            </div>
                        }
                        @if (extra > 0)
                        {
                            <div class="attachment-thumb more-files">
                                <span>@extra+</span>
                                <small>Files</small>
                            </div>
                        }
                    </div>
                }

                @await Html.PartialAsync("_RatingWidget", rec)
            </div>
        }

        <div id="noFilterResults" hidden style="text-align:center;padding:60px;color:#888;">
            <p>No recommendations match your filters.</p>
        </div>
    </div>
</div>

<!-- Leaderboard View -->
<div id="leaderboardView" class="view-section">
    <div class="leaderboard-wrapper">
        <div class="leaderboard-feed">

            @if (!Model.TopRated.Any())
            {
                <div style="text-align:center;padding:60px;color:#888;">
                    <p>No recommendations yet.</p>
                </div>
            }

            @for (int rank = 0; rank < Model.TopRated.Count; rank++)
            {
                var rec = Model.TopRated[rank];
                <div class="leaderboard-item">
                    <div class="rank-col">
                        <div class="rank-arrow @(rank == 0 ? "up" : "down")">@(rank == 0 ? "▲" : "▼")</div>
                        <div class="rank-number">@(rank + 1)</div>
                    </div>
                    <div class="proposal-card leaderboard-card">
                        <div class="card-header">
                            <div class="author-info">
                                <div class="avatar">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <circle cx="12" cy="8" r="4" />
                                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                    </svg>
                                </div>
                                <div class="author-name">@rec.CitizenName</div>
                            </div>
                            <div class="card-date">@rec.ApprovedAt.ToString("MM/dd/yy")</div>
                        </div>
                        <div class="card-meta">
                            @if (!string.IsNullOrEmpty(rec.AssignedOffice))
                            {
                                <span class="meta-label">Office: <span class="meta-value">@rec.AssignedOffice</span></span>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="proposal-title">Citizen Recommendation: @rec.Title</h3>
                            <p class="proposal-excerpt">@rec.Description</p>
                        </div>

                        @if (rec.AttachmentPaths.Any())
                        {
                            <div class="attachments">
                                @{
                                    var maxShow2 = Math.Min(2, rec.AttachmentPaths.Count);
                                    var extra2 = rec.AttachmentPaths.Count - maxShow2;
                                }
                                @for (int i = 0; i < maxShow2; i++)
                                {
                                    var path = rec.AttachmentPaths[i];
                                    var type = rec.AttachmentTypes[i];
                                    <div class="attachment-thumb">
                                        @if (type == "image" || type.StartsWith("image/"))
                                        {
                                            <img src="@path" alt="attachment" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />
                                        }
                                        else if (type == "video" || type.StartsWith("video/"))
                                        {
                                            <video controls preload="metadata" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">
                                                <source src="@path" />
                                                Your browser does not support video playback.
                                            </video>
                                        }
                                        else
                                        {
                                            <div class="thumb-placeholder">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                                    <polyline points="14,2 14,8 20,8" />
                                                </svg>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (extra2 > 0)
                                {
                                    <div class="attachment-thumb more-files">
                                        <span>@extra2+</span>
                                        <small>Files</small>
                                    </div>
                                }
                            </div>
                        }

                        <div class="leaderboard-votes rating-summary">
                            <span class="rating-chip urgency">Urgency @rec.AvgUrgency.ToString("0.0")★</span>
                            <span class="rating-chip relevance">Relevance @rec.AvgRelevance.ToString("0.0")★</span>
                            <span class="rating-chip feasibility">Feasibility @rec.AvgFeasibility.ToString("0.0")★</span>
                            <span class="rating-count">@rec.RatingCount rating@(rec.RatingCount == 1 ? "" : "s")</span>
                        </div>
                        <button type="button" class="leaderboard-open-btn js-open-recommendation" data-rec-id="@rec.Id">View &amp; Rate Recommendation</button>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar: Leaderboard insights -->
        <aside class="ranking-sidebar">
            <div class="ranking-box">
                @{
                    var highestRankedRecommendation = Model.TopRated.FirstOrDefault();
                    var topTenRatingCount = Model.TopRated.Sum(r => r.RatingCount);
                }
                <div class="ranking-header">
                    <svg class="trophy-icon" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18 2H6a2 2 0 00-2 2v2c0 2.21 1.79 4 4 4h1v2c0 2.33 1.59 4.28 3.74 4.83C12.3 19.46 11 21.08 11 23h2c0-1.92-1.3-3.54-1.74-4.17 2.15-.55 3.74-2.5 3.74-4.83v-2h1c2.21 0 4-1.79 4-4V4a2 2 0 00-2-2zM6 8c-1.1 0-2-.9-2-2V4h2v4zm14-2c0 1.1-.9 2-2 2V4h2v2z" />
                    </svg>
                    <h2 class="ranking-title">LEADERBOARD INSIGHTS</h2>
                </div>
                <div class="leaderboard-insights">
                    <section class="insight-section">
                        <span class="insight-label">How ranking works</span>
                        <p>Each score combines citizen ratings for urgency, relevance, and feasibility.</p>
                    </section>
                    <section class="insight-section">
                        <span class="insight-label">Top recommendation</span>
                        <strong>@(highestRankedRecommendation?.Title ?? "No ranked recommendation yet")</strong>
                        @if (highestRankedRecommendation != null)
                        {
                            <span class="insight-score">@highestRankedRecommendation.CompositeScore.ToString("0.0")★ combined score</span>
                        }
                    </section>
                    <section class="insight-section insight-stats">
                        <div><strong>@Model.TopRated.Count</strong><span>ranked proposals</span></div>
                        <div><strong>@topTenRatingCount</strong><span>citizen ratings</span></div>
                    </section>
                    <p class="insight-help">Your ratings help LGUs identify which proposals citizens consider most important.</p>
                </div>
                <div class="ranking-list">
                    @for (int i = 0; i < Model.TopRated.Count; i++)
                    {
                        var r = Model.TopRated[i];
                        var shortTitle = r.Title.Length > 22 ? r.Title.Substring(0, 22) + "..." : r.Title;
                        <button type="button" class="mini-rank-item mini-rank-link js-open-recommendation" data-rec-id="@r.Id" aria-label="View and rate @r.Title">
                            <span class="mini-number">@(i + 1)</span>
                            <div class="mini-content">
                                <p class="mini-title">@shortTitle</p>
                                <div class="mini-votes">
                                    <span class="up">@r.CompositeScore.ToString("0.0")★ <small>score</small></span>
                                    <span class="down">@r.RatingCount <small>ratings</small></span>
                                </div>
                            </div>
                        </button>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

<button type="button" id="backToTopBtn" class="back-to-top-btn" hidden aria-label="Back to top" title="Back to top">
    <span aria-hidden="true">↑</span>
    <span class="back-to-top-label">Top</span>
</button>

@section Scripts {
    <script>
        // Tab switching
        const tabButtons = document.querySelectorAll('.tab-btn');
        const proposalsView = document.getElementById('proposalsView');
        const leaderboardView = document.getElementById('leaderboardView');
        const pageTitle = document.querySelector('.page-title');
        const headerRight = document.querySelector('.header-right');
        const tabIndicator = document.querySelector('.tab-indicator');
        const backToTopBtn = document.getElementById('backToTopBtn');

        function updateBackToTopVisibility() {
            backToTopBtn.hidden = window.scrollY < 360;
        }

        window.addEventListener('scroll', updateBackToTopVisibility, { passive: true });
        backToTopBtn.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        tabButtons.forEach((btn, index) => {
            btn.addEventListener('click', () => {
                tabButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                tabIndicator.style.transform = `translateX(${index * 100}%)`;
                if (btn.dataset.view === "proposals") {
                    proposalsView.classList.add("active-view");
                    leaderboardView.classList.remove("active-view");
                    headerRight.style.display = "flex";
                    pageTitle.textContent = "Discover";
                } else {
                    proposalsView.classList.remove("active-view");
                    leaderboardView.classList.add("active-view");
                    headerRight.style.display = "none";
                    pageTitle.textContent = "Leaderboard";
                }
            });
        });

        // Search + office filter + date sort
        const searchInput = document.getElementById('searchInput');
        const officeFilter = document.getElementById('officeFilter');
        const periodFilter = document.getElementById('periodFilter');
        const dateSort = document.getElementById('dateSort');
        const proposalsFeed = document.getElementById('proposalsFeed');
        const noFilterResults = document.getElementById('noFilterResults');

        function escapeHtml(str) {
            return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        function escapeRegex(str) {
            return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }
        function highlightMatches(el, query) {
            const original = el.textContent;
            if (!query) {
                el.textContent = original;
                return;
            }
            const re = new RegExp(escapeRegex(query), 'gi');
            el.innerHTML = escapeHtml(original).replace(re, m => `<mark class="search-highlight">${m}</mark>`);
        }

        function parseCardDate(value) {
            const [year, month, day] = value.split('-').map(Number);
            return new Date(year, month - 1, day);
        }

        function matchesPeriod(cardDate, period) {
            if (!period) return true;

            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (period === 'day')
                return cardDate.getTime() === today.getTime();

            if (period === 'week') {
                const weekStart = new Date(today);
                const daysSinceMonday = (today.getDay() + 6) % 7;
                weekStart.setDate(today.getDate() - daysSinceMonday);
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekStart.getDate() + 7);
                return cardDate >= weekStart && cardDate < weekEnd;
            }

            if (period === 'month')
                return cardDate.getFullYear() === today.getFullYear()
                    && cardDate.getMonth() === today.getMonth();

            return cardDate.getFullYear() === today.getFullYear();
        }

        function applyFilters() {
            const query = (searchInput.value || '').toLowerCase().trim();
            const office = officeFilter.value;
            const period = periodFilter.value;

            const cards = Array.from(proposalsFeed.querySelectorAll('.proposal-card'));
            let visibleCount = 0;

            cards.forEach(card => {
                const title = card.dataset.title || '';
                const desc = card.dataset.description || '';
                const cardCategory = card.dataset.category || '';
                const cardOffice = card.dataset.office || '';
                const cardDate = parseCardDate(card.dataset.date);

                const matchesQuery = !query || title.includes(query) || desc.includes(query) || cardCategory.includes(query);
                const matchesOffice = !office || cardOffice === office;
                const matchesDate = matchesPeriod(cardDate, period);
                const isVisible = matchesQuery && matchesOffice && matchesDate;
                card.style.display = isVisible ? '' : 'none';
                if (isVisible) visibleCount++;

                const titleEl = card.querySelector('.proposal-title');
                const descEl = card.querySelector('.proposal-excerpt');
                if (titleEl) highlightMatches(titleEl, query);
                if (descEl) highlightMatches(descEl, query);
            });

            const sorted = cards.slice().sort((a, b) => {
                const da = parseCardDate(a.dataset.date);
                const db = parseCardDate(b.dataset.date);
                return dateSort.value === 'asc' ? da - db : db - da;
            });
            sorted.forEach(card => proposalsFeed.appendChild(card));
            noFilterResults.hidden = visibleCount !== 0;
        }

        searchInput.addEventListener('input', applyFilters);
        officeFilter.addEventListener('change', applyFilters);
        periodFilter.addEventListener('change', applyFilters);
        dateSort.addEventListener('change', applyFilters);

        document.querySelectorAll('.js-open-recommendation').forEach(button => {
            button.addEventListener('click', () => {
                const proposalTab = document.querySelector('.tab-btn[data-view="proposals"]');
                proposalTab.click();

                // A leaderboard result should always be reachable, even when the
                // citizen had previously applied a Discover filter.
                searchInput.value = '';
                officeFilter.value = '';
                periodFilter.value = '';
                applyFilters();

                const card = proposalsFeed.querySelector(`.proposal-card[data-rec-id="${button.dataset.recId}"]`);
                if (!card) return;

                card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                card.classList.remove('recommendation-focus');
                requestAnimationFrame(() => card.classList.add('recommendation-focus'));

                const rateButton = card.querySelector('.btn-start-rating');
                if (rateButton) rateButton.click();
            });
        });

        // Multi-category star rating
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                   ?? document.cookie.split('; ').find(r => r.startsWith('XSRF-TOKEN'))?.split('=')[1];

        function paintStars(starsEl, upTo) {
            starsEl.querySelectorAll('.star').forEach(star => {
                star.classList.toggle('filled', Number(star.dataset.value) <= upTo);
            });
        }

        document.querySelectorAll('.rating-widget .stars').forEach(starsEl => {
            starsEl.querySelectorAll('.star').forEach(star => {
                star.addEventListener('mouseenter', () => paintStars(starsEl, Number(star.dataset.value)));
                star.addEventListener('click', () => {
                    starsEl.dataset.selected = star.dataset.value;
                    paintStars(starsEl, Number(star.dataset.value));
                });
            });
            starsEl.addEventListener('mouseleave', () => paintStars(starsEl, Number(starsEl.dataset.selected || 0)));
        });

        document.querySelectorAll('.rating-widget .btn-start-rating').forEach(btn => {
            btn.addEventListener('click', () => {
                const widget = btn.closest('.rating-widget');
                widget.querySelector('.rating-editor').classList.remove('is-hidden');
                btn.closest('.rating-start-action').hidden = true;
            });
        });

        document.querySelectorAll('.rating-widget .btn-cancel-rating').forEach(btn => {
            btn.addEventListener('click', () => {
                const widget = btn.closest('.rating-widget');
                widget.querySelectorAll('.stars').forEach(starsEl => {
                    starsEl.dataset.selected = '0';
                    paintStars(starsEl, 0);
                });
                widget.querySelector('.rating-editor').classList.add('is-hidden');
                widget.querySelector('.rating-start-action').hidden = false;
            });
        });

        document.querySelectorAll('.rating-widget .btn-submit-rating').forEach(btn => {
            btn.addEventListener('click', async () => {
                const widget = btn.closest('.rating-widget');
                const feedback = widget.querySelector('.rating-feedback');
                const recId = widget.dataset.recId;
                const groups = widget.querySelectorAll('.stars');

                const values = {};
                for (const g of groups) {
                    const selected = Number(g.dataset.selected || 0);
                    if (selected < 1) {
                        feedback.textContent = 'Please rate all three categories before submitting.';
                        return;
                    }
                    values[g.dataset.category] = selected;
                }

                const formData = new FormData();
                formData.append('recommendationId', recId);
                formData.append('urgencyStars', values.urgency);
                formData.append('relevanceStars', values.relevance);
                formData.append('feasibilityStars', values.feasibility);
                formData.append('__RequestVerificationToken', token);

                btn.disabled = true;
                feedback.textContent = 'Submitting…';

                try {
                    const res = await fetch('?handler=Rate', { method: 'POST', body: formData });
                    if (!res.ok) {
                        const errorMessage = await res.text();
                        feedback.textContent = errorMessage || 'Could not submit your rating. Please try again.';
                        return;
                    }
                    const data = await res.json();

                    widget.querySelector('.composite-score').textContent = data.compositeScore.toFixed(1) + '★';
                    widget.querySelector('.rating-count-label').textContent =
                        `(${data.ratingCount} rating${data.ratingCount === 1 ? '' : 's'})`;
                    widget.querySelector('[data-avg-for="urgency"]').textContent = `avg ${data.avgUrgency.toFixed(1)}`;
                    widget.querySelector('[data-avg-for="relevance"]').textContent = `avg ${data.avgRelevance.toFixed(1)}`;
                    widget.querySelector('[data-avg-for="feasibility"]').textContent = `avg ${data.avgFeasibility.toFixed(1)}`;

                    groups.forEach(group => {
                        group.classList.remove('stars');
                        group.classList.add('stars-readonly');
                        group.style.pointerEvents = 'none';
                    });
                    btn.remove();
                    widget.querySelector('.btn-cancel-rating')?.remove();
                    feedback.textContent = 'Thanks for rating! You can only rate a recommendation once.';
                } finally {
                    if (btn.isConnected) btn.disabled = false;
                }
            });
        });

        // ── Realtime feed ──
        // Pushed instantly over SignalR (see FeedHub / VoxAngelos.Hubs) whenever anyone
        // else rates a post or an LGU publishes a new recommendation — no refresh needed.
        function applyRatingUpdate(data) {
            const widget = document.querySelector(`.rating-widget[data-rec-id="${data.recommendationId}"]`);
            if (!widget) return;
            widget.querySelector('.composite-score').textContent = data.compositeScore.toFixed(1) + '★';
            widget.querySelector('.rating-count-label').textContent =
                `(${data.ratingCount} rating${data.ratingCount === 1 ? '' : 's'})`;
            widget.querySelector('[data-avg-for="urgency"]').textContent = `avg ${data.avgUrgency.toFixed(1)}`;
            widget.querySelector('[data-avg-for="relevance"]').textContent = `avg ${data.avgRelevance.toFixed(1)}`;
            widget.querySelector('[data-avg-for="feasibility"]').textContent = `avg ${data.avgFeasibility.toFixed(1)}`;
        }

        function refreshProposalsFeed() {
            fetch(window.location.href)
                .then(res => res.text())
                .then(html => {
                    const doc = new DOMParser().parseFromString(html, 'text/html');
                    const newFeed = doc.getElementById('proposalsFeed');
                    if (newFeed) {
                        proposalsFeed.innerHTML = newFeed.innerHTML;
                        applyFilters();
                    }
                })
                .catch(() => { });
        }

        window.VoxAngelosRealtime = {
            onRatingUpdated: applyRatingUpdate,
            onPostPublished: refreshProposalsFeed
        };
    </script>
}

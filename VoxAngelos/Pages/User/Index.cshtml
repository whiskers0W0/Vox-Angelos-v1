@page
@model VoxAngelos.Pages.User.IndexModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Discover";
}

@section Styles {
    <link rel="stylesheet" href="~/css/citizen-discover.css" />
}

<div class="content-header">
    <h1 class="page-title">Discover</h1>
    <div class="header-right">
        <div class="search-box">
            <input type="text" placeholder="Search" class="search-input" id="searchInput" />
            <button class="search-btn" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </button>
        </div>
    </div>
</div>
@* to prove the request is coming from your own page and not from a malicious site *@
@Html.AntiForgeryToken()

<!-- Toggle Tabs -->
<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="proposals">Citizen Recommendations</button>
    <button class="tab-btn" data-view="leaderboard">Top Votes</button>
</div>

<!-- Proposals View -->
<div id="proposalsView" class="view-section active-view">
    <div class="proposals-feed" id="proposalsFeed">

        @if (!Model.Recommendations.Any())
        {
            <div style="text-align:center;padding:60px;color:#888;">
                <p>No approved recommendations yet.</p>
            </div>
        }

        @foreach (var rec in Model.Recommendations)
        {
            <div class="proposal-card" data-title="@rec.Title.ToLower()" data-description="@rec.Description.ToLower()">
                <div class="card-header">
                    <div class="author-info">
                        <div class="avatar">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg>
                        </div>
                        <div class="author-name">@rec.CitizenName</div>
                    </div>
                    <div class="card-date">@rec.ApprovedAt.ToString("MM/dd/yy")</div>
                </div>

                <div class="card-meta">
                    <span class="meta-label">Category: <span class="meta-value">@rec.Category</span></span>
                    @if (!string.IsNullOrEmpty(rec.AssignedOffice))
                    {
                        <span class="meta-label">Office: <span class="meta-value">@rec.AssignedOffice</span></span>
                    }
                </div>

                <div class="card-body">
                    <h3 class="proposal-title">Citizen Recommendation: @rec.Title</h3>
                    <p class="proposal-excerpt">@rec.Description</p>
                </div>

                @if (rec.AttachmentPaths.Any())
                {
                    <div class="attachments">
                        @{
                            var maxShow = Math.Min(2, rec.AttachmentPaths.Count);
                            var extra = rec.AttachmentPaths.Count - maxShow;
                        }
                        @for (int i = 0; i < maxShow; i++)
                        {
                            var path = rec.AttachmentPaths[i];
                            var type = rec.AttachmentTypes[i];
                            <div class="attachment-thumb">
                                @if (type.StartsWith("image/"))
                                {
                                    <img src="@path" alt="attachment" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />
                                }
                                else
                                {
                                    <div class="thumb-placeholder">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                            <polyline points="14,2 14,8 20,8" />
                                        </svg>
                                    </div>
                                }
                            </div>
                        }
                        @if (extra > 0)
                        {
                            <div class="attachment-thumb more-files">
                                <span>@extra+</span>
                                <small>Files</small>
                            </div>
                        }
                    </div>
                }

                <div class="vote-bar">
                    <button class="vote-btn upvote @(rec.CurrentUserVote == "up" ? "voted" : "")"
                            data-rec-id="@rec.Id" data-vote-type="up" aria-label="Upvote">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="3">
                            <path d="M12 3 Q12.8 3 13.3 3.7 L21.2 18.5 Q21.6 19.3 21.1 20 Q20.6 20.7 19.7 20.7 H4.3 Q3.4 20.7 2.9 20 Q2.4 19.3 2.8 18.5 L10.7 3.7 Q11.2 3 12 3 Z" />
                        </svg>
                        <span class="upvote-count">@rec.Upvotes</span>
                    </button>
                    <button class="vote-btn downvote @(rec.CurrentUserVote == "down" ? "voted" : "")"
                            data-rec-id="@rec.Id" data-vote-type="down" aria-label="Downvote">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="3">
                            <path d="M12 21 Q11.2 21 10.7 20.3 L2.8 5.5 Q2.4 4.7 2.9 4 Q3.4 3.3 4.3 3.3 H19.7 Q20.6 3.3 21.1 4 Q21.6 4.7 21.2 5.5 L13.3 20.3 Q12.8 21 12 21 Z" />
                        </svg>
                        <span class="downvote-count">@rec.Downvotes</span>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<!-- Leaderboard View -->
<div id="leaderboardView" class="view-section">
    <div class="leaderboard-wrapper">
        <div class="leaderboard-feed">

            @if (!Model.TopVotes.Any())
            {
                <div style="text-align:center;padding:60px;color:#888;">
                    <p>No recommendations yet.</p>
                </div>
            }

            @for (int rank = 0; rank < Model.TopVotes.Count; rank++)
            {
                var rec = Model.TopVotes[rank];
                var isUp = rank == 0 || rec.Upvotes >= (rank > 0 ? Model.TopVotes[rank - 1].Upvotes : 0);
                <div class="leaderboard-item">
                    <div class="rank-col">
                        <div class="rank-arrow @(rank == 0 ? "up" : "down")">@(rank == 0 ? "▲" : "▼")</div>
                        <div class="rank-number">@(rank + 1)</div>
                    </div>
                    <div class="proposal-card leaderboard-card">
                        <div class="card-header">
                            <div class="author-info">
                                <div class="avatar">
                                    <svg viewBox="0 0 24 24" fill="currentColor">
                                        <circle cx="12" cy="8" r="4" />
                                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                    </svg>
                                </div>
                                <div class="author-name">@rec.CitizenName</div>
                            </div>
                            <div class="card-date">@rec.ApprovedAt.ToString("MM/dd/yy")</div>
                        </div>
                        <div class="card-meta">
                            <span class="meta-label">Category: <span class="meta-value">@rec.Category</span></span>
                            @if (!string.IsNullOrEmpty(rec.AssignedOffice))
                            {
                                <span class="meta-label">Office: <span class="meta-value">@rec.AssignedOffice</span></span>
                            }
                        </div>
                        <div class="card-body">
                            <h3 class="proposal-title">Citizen Recommendation: @rec.Title</h3>
                            <p class="proposal-excerpt">@rec.Description</p>
                        </div>

                        @if (rec.AttachmentPaths.Any())
                        {
                            <div class="attachments">
                                @{
                                    var maxShow2 = Math.Min(2, rec.AttachmentPaths.Count);
                                    var extra2 = rec.AttachmentPaths.Count - maxShow2;
                                }
                                @for (int i = 0; i < maxShow2; i++)
                                {
                                    var path = rec.AttachmentPaths[i];
                                    var type = rec.AttachmentTypes[i];
                                    <div class="attachment-thumb">
                                        @if (type.StartsWith("image/"))
                                        {
                                            <img src="@path" alt="attachment" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" />
                                        }
                                        else
                                        {
                                            <div class="thumb-placeholder">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                                    <polyline points="14,2 14,8 20,8" />
                                                </svg>
                                            </div>
                                        }
                                    </div>
                                }
                                @if (extra2 > 0)
                                {
                                    <div class="attachment-thumb more-files">
                                        <span>@extra2+</span>
                                        <small>Files</small>
                                    </div>
                                }
                            </div>
                        }

                        <div class="leaderboard-votes">
                            <span class="leader-upvotes">@rec.Upvotes Upvotes</span>
                            <span class="leader-downvotes">@rec.Downvotes Downvotes</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar: Top 10 mini list -->
        <aside class="ranking-sidebar">
            <div class="ranking-box">
                <div class="ranking-header">
                    <svg class="trophy-icon" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18 2H6a2 2 0 00-2 2v2c0 2.21 1.79 4 4 4h1v2c0 2.33 1.59 4.28 3.74 4.83C12.3 19.46 11 21.08 11 23h2c0-1.92-1.3-3.54-1.74-4.17 2.15-.55 3.74-2.5 3.74-4.83v-2h1c2.21 0 4-1.79 4-4V4a2 2 0 00-2-2zM6 8c-1.1 0-2-.9-2-2V4h2v4zm14-2c0 1.1-.9 2-2 2V4h2v2z" />
                    </svg>
                    <h2 class="ranking-title">TOP 10 RECOMMENDATIONS <br /> (ALL TIME)</h2>
                </div>
                <div class="ranking-list">
                    @for (int i = 0; i < Model.TopVotes.Count; i++)
                    {
                        var r = Model.TopVotes[i];
                        var shortTitle = r.Title.Length > 22 ? r.Title.Substring(0, 22) + "..." : r.Title;
                        <div class="mini-rank-item">
                            <span class="mini-number">@(i + 1)</span>
                            <div class="mini-content">
                                <p class="mini-title">@shortTitle</p>
                                <div class="mini-votes">
                                    <span class="up">@r.Upvotes ▲ <small>votes</small></span>
                                    <span class="down">@r.Downvotes ▼ <small>votes</small></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching
        const tabButtons = document.querySelectorAll('.tab-btn');
        const proposalsView = document.getElementById('proposalsView');
        const leaderboardView = document.getElementById('leaderboardView');
        const pageTitle = document.querySelector('.page-title');
        const headerRight = document.querySelector('.header-right');
        const tabIndicator = document.querySelector('.tab-indicator');

        tabButtons.forEach((btn, index) => {
            btn.addEventListener('click', () => {
                tabButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                tabIndicator.style.transform = `translateX(${index * 100}%)`;
                if (btn.dataset.view === "proposals") {
                    proposalsView.classList.add("active-view");
                    leaderboardView.classList.remove("active-view");
                    headerRight.style.display = "flex";
                    pageTitle.textContent = "Discover";
                } else {
                    proposalsView.classList.remove("active-view");
                    leaderboardView.classList.add("active-view");
                    headerRight.style.display = "none";
                    pageTitle.textContent = "Leaderboard";
                }
            });
        });

        // Search filter
        document.getElementById('searchInput').addEventListener('input', function () {
            const query = this.value.toLowerCase();
            document.querySelectorAll('#proposalsFeed .proposal-card').forEach(card => {
                const title = card.dataset.title || '';
                const desc = card.dataset.description || '';
                card.style.display = (title.includes(query) || desc.includes(query)) ? '' : 'none';
            });
        });

        // Voting
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                   ?? document.cookie.split('; ').find(r => r.startsWith('XSRF-TOKEN'))?.split('=')[1];

        document.querySelectorAll('.vote-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const recId = btn.dataset.recId;
                const voteType = btn.dataset.voteType;
                const card = btn.closest('.proposal-card');

                const formData = new FormData();
                formData.append('recommendationId', recId);
                formData.append('voteType', voteType);
                formData.append('__RequestVerificationToken', token);

                const res = await fetch('?handler=Vote', {
                    method: 'POST',
                    body: formData
                });

                if (!res.ok) return;
                const data = await res.json();

                // Update counts
                card.querySelector('.upvote-count').textContent = data.upvotes;
                card.querySelector('.downvote-count').textContent = data.downvotes;

                setTimeout(() => location.reload(), 300); //refreshes the page so the top vote updates
                // Update voted state
                const upBtn = card.querySelector('.upvote');
                const downBtn = card.querySelector('.downvote');
                upBtn.classList.toggle('voted', data.userVote === 'up');
                downBtn.classList.toggle('voted', data.userVote === 'down');
            });
        });
    </script>
}
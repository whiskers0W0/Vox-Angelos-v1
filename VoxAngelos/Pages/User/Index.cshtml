@page
@model IndexModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Discover";
}

@section Styles {
    <link rel="stylesheet" href="~/css/citizen-discover.css" />
}

<div class="content-header">
    <h1 class="page-title">Discover</h1>
    <div class="header-right">
        <div class="search-box">
            <input type="text" placeholder="Search" class="search-input" />
            <button class="search-btn" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </button>
        </div>
    </div>
</div>

<!-- Toggle Tabs -->
<div class="tab-group">
    <div class="tab-indicator"></div>
    <button class="tab-btn active" data-view="proposals">Proposals</button>
    <button class="tab-btn" data-view="leaderboard">Top Votes</button>
</div>

<div class="leaderboard-filter" id="leaderboardFilter">
    <span class="filter-label">As of:</span>
    <select class="leaderboard-select">
        <option value="all">All Time</option>
        <option value="year">This Year</option>
        <option value="month">This Month</option>
        <option value="week">This Week</option>
    </select>
</div>

<!-- Proposals View -->

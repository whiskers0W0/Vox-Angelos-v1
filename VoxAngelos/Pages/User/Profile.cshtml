@page
@model VoxAngelos.Pages.User.ProfileModel
@{
    Layout = "_CitizenLayout";
    ViewData["Title"] = "Profile";
    var profile = Model.Profile;
    var displayName = string.IsNullOrWhiteSpace(profile.DisplayName) ? "Citizen" : profile.DisplayName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/citizen-profile.css" asp-append-version="true" />
}

<div class="content-header">
    <h1 class="page-title">Profile</h1>
</div>

<div class="profile-container">
    <div class="profile-card-wrapper">
        <div class="profile-avatar-wrap">
            <div class="profile-avatar" aria-label="Citizen profile avatar">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
                </svg>
            </div>
        </div>

        <div class="profile-card">
            <div class="profile-header-info">
                <h2 class="user-display-name">@displayName</h2>
                <span class="user-role-badge">Verified Citizen</span>
            </div>

            <p class="profile-security-note">Your identity information is protected and cannot be changed from this page.</p>

            <div class="profile-fields-grid">
                <div class="profile-field">
                    <label>First Name</label>
                    <div class="field-value-box">@(profile.FirstName ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Middle Name</label>
                    <div class="field-value-box">@(profile.MiddleName ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Last Name</label>
                    <div class="field-value-box">@(profile.LastName ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Phone Number</label>
                    <div class="field-value-box">@(profile.PhoneNumber ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Barangay</label>
                    <div class="field-value-box">@(profile.Barangay ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>City</label>
                    <div class="field-value-box">@(profile.City ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Email Address</label>
                    <div class="field-value-box">@(profile.EmailAddress ?? "Not available")</div>
                    <small class="profile-readonly-note">Change this securely from Account Security in the sidebar.</small>
                </div>
                <div class="profile-field">
                    <label>Birth Date</label>
                    <div class="field-value-box">@(profile.BirthDate?.ToString("MMMM dd, yyyy") ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>Identification Type</label>
                    <div class="field-value-box">@(profile.IdType ?? "Not available")</div>
                </div>
                <div class="profile-field">
                    <label>ID Document</label>
                    @if (!string.IsNullOrWhiteSpace(profile.IdDocumentPath))
                    {
                        <a class="field-value-box link" href="@profile.IdDocumentPath" target="_blank" rel="noopener">View verified document</a>
                    }
                    else
                    {
                        <div class="field-value-box">Not available</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

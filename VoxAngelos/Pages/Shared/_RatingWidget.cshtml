@model VoxAngelos.Pages.User.IndexModel.RecommendationCardViewModel

@{
    var canRate = !Model.IsOwnRecommendation && !Model.HasRated;
    var categories = new (string Key, string Label, int Mine, double Avg)[]
    {
        ("urgency", "Urgency", Model.MyUrgency, Model.AvgUrgency),
        ("relevance", "Relevance", Model.MyRelevance, Model.AvgRelevance),
        ("feasibility", "Feasibility", Model.MyFeasibility, Model.AvgFeasibility),
    };
}

<div class="rating-widget" data-rec-id="@Model.Id">
    <div class="rating-summary-line">
        <span class="composite-score">@Model.CompositeScore.ToString("0.0")★</span>
        <span class="rating-count-label">(@Model.RatingCount rating@(Model.RatingCount == 1 ? "" : "s"))</span>
    </div>

    @if (canRate)
    {
        <div class="rating-actions rating-start-action">
            <button type="button" class="btn-start-rating">Rate Recommendation</button>
        </div>
    }

    <div class="rating-editor @(canRate ? "is-hidden" : "")">
        @foreach (var cat in categories)
        {
            <div class="rating-category">
                <span class="category-label">@cat.Label</span>
                <span class="@(canRate ? "stars" : "stars-readonly")" data-category="@cat.Key" data-selected="@cat.Mine">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <svg class="star @(s <= cat.Mine ? "filled" : "")" data-value="@s" viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="12 2 15 9 22 9.5 17 14.5 18.5 21.5 12 17.8 5.5 21.5 7 14.5 2 9.5 9 9" />
                        </svg>
                    }
                </span>
                <span class="category-avg" data-avg-for="@cat.Key">avg @cat.Avg.ToString("0.0")</span>
            </div>
        }

        <div class="rating-actions">
            @if (Model.IsOwnRecommendation)
            {
                <span class="rating-feedback" role="status">You cannot rate your own recommendation.</span>
            }
            else if (Model.HasRated)
            {
                <span class="rating-feedback" role="status">You have already rated this recommendation.</span>
            }
            else
            {
                <button type="button" class="btn-submit-rating">Submit Rating</button>
                <button type="button" class="btn-cancel-rating">Cancel</button>
                <span class="rating-feedback" role="status"></span>
            }
        </div>
    </div>
</div>

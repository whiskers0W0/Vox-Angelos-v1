@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var userEmail = User.Identity?.Name ?? "";
    var prefix = userEmail.Contains("@") ? userEmail.Split('@')[0] : userEmail;

    var departmentMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "socialwelfare",  "Social Welfare" },
        { "publicsafety",   "Public Safety"  },
        { "health",         "Health"         },
        { "agriculture",    "Agriculture"    },
        { "engineering",    "Engineering"    },
        { "admin",          "Admin"          },
    };

    var departmentName = departmentMap.TryGetValue(prefix, out var dName) ? dName : prefix;

    bool IsActive(string path) => currentPage.StartsWith(path, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | LGU</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/lgu_layout.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    @{
        var path = Context.Request.Path.Value?.ToLower() ?? "";
    }

    <div class="layout-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="~/assets/VoxAngelosLogo.png" class="brand-logo">
                    <span class="brand-name">ox Angelos</span>
                </div>

                <div class="sidebar-dept">
                    <div class="sidebar-dept-label">Department</div>
                    <div class="sidebar-dept-name">@departmentName</div>
                </div>

                <hr class="sidebar-divider" />

                <nav class="sidebar-nav">

                    <a asp-page="/LGU/Dashboard" class="nav-item @(IsActive("/LGU/Dashboard") ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" rx="1" />
                            <rect x="14" y="3" width="7" height="7" rx="1" />
                            <rect x="3" y="14" width="7" height="7" rx="1" />
                            <rect x="14" y="14" width="7" height="7" rx="1" />
                        </svg>
                        <span>Dashboard</span>
                    </a>

                    <a asp-page="/LGU/Index" class="nav-item @(IsActive("/LGU/Index") ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" />
                            <path d="M9 21V12h6v9" />
                        </svg>
                        <span>
                        View Concerns
                        </span>
                    </a>

                    <a asp-page="/LGU/ReviewRecommendations" class="nav-item @(IsActive("/LGU/ReviewRecommendations") ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                            <rect x="8" y="2" width="8" height="4" rx="1" ry="1" />
                            <line x1="8" y1="11" x2="16" y2="11" />
                            <line x1="8" y1="16" x2="12" y2="16" />
                            <polyline points="14 15 16 17 20 13" />
                        </svg>
                        <span>Review Recommendations</span>
                    </a>

                    <a asp-page="/LGU/Leaderboard" class="nav-item @(IsActive("/LGU/Leaderboard") ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 20V10M12 20V4M6 20v-6" />
                        </svg>
                        <span>
                        View Leaderboard
                        </span>
                    </a>

                    <a asp-page="/LGU/Heatmap" class="nav-item @(IsActive("/LGU/Heatmap") ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="10" r="3" />
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                        </svg>
                        <span>
                        View Heatmap
                        </span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                <form method="post" action="/Identity/Account/Logout" class="w-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="/LGU/Login" />
                    <button type="submit" class="nav-item logout-btn w-100 border-0 bg-transparent text-start">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                            <polyline points="16,17 21,12 16,7" />
                            <line x1="21" y1="12" x2="9" y2="12" />
                        </svg>
                        <span>Log Out</span>
                    </button>
                </form>
                </div>
            </aside>

            <!-- Mobile top bar -->
            <div class="mobile-topbar">
                <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div class="mobile-brand">
                    <img src="~/assets/VoxAngelosLogo.png" class="brand-v">
                        <span>ox Angelos</span>
                    </div>
                </div>

                <!-- Sidebar overlay -->
                <div class="sidebar-overlay" id="sidebarOverlay"></div>

                <!-- Page Content -->
                <main class="main-content">
                    @RenderBody()
                </main>
            </div>

            
            <script>
                    const hamburgerBtn = document.getElementById('hamburgerBtn');
                    const sidebar = document.querySelector('.sidebar');
                    const overlay = document.getElementById('sidebarOverlay');

                    hamburgerBtn.addEventListener('click', () => {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('active');
                    });

                    overlay.addEventListener('click', () => {
                        sidebar.classList.remove('open');
                        overlay.classList.remove('active');
                    });
            </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
            @RenderSection("Scripts", required: false)
        </body>

    </html>
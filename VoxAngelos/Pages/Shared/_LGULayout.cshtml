@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var userEmail = User.Identity?.Name ?? "";
    var prefix = userEmail.Contains("@") ? userEmail.Split('@')[0] : userEmail;

    var departmentMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "socialwelfare",  "Social Welfare" },
        { "publicsafety",   "Public Safety"  },
        { "health",         "Health"         },
        { "agriculture",    "Agriculture"    },
        { "engineering",    "Engineering"    },
        { "admin",          "Admin"          },
    };

    var departmentName = departmentMap.TryGetValue(prefix, out var dName) ? dName : prefix;

    bool IsActive(string path) => currentPage.StartsWith(path, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – VoxAngelos LGU</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard_lgu.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── Sidebar (desktop) ── -->
    <aside class="lgu-sidebar d-none d-lg-flex" id="desktopSidebar">

        <!-- Logo -->
        <div class="sidebar-logo">
            <a class="sidebar-logo-mark" href="/LGU">
                <img src="~/images/Logo-VoxAngelos.png" alt="Vox Angelos" class="sidebar-logo-img" />
            </a>
        </div>

        <!-- Department badge -->
        <div class="sidebar-dept">
            <div class="sidebar-dept-label">Department</div>
            <div class="sidebar-dept-name">@departmentName</div>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <div class="sidebar-nav-label">Menu</div>

            <a asp-page="/LGU/Index"
                   class="sidebar-link @(IsActive("/LGU/Index") ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" />
                    <path d="M9 21V12h6v9" />
                </svg>
                View Concerns
            </a>

            <a asp-page="/LGU/Leaderboard"
                   class="sidebar-link @(IsActive("/LGU/Leaderboard") ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 20V10M12 20V4M6 20v-6" />
                </svg>
                View Leaderboard
            </a>

            <a asp-page="/LGU/Heatmap"
                   class="sidebar-link @(IsActive("/LGU/Heatmap") ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3" />
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                </svg>
                View Heatmap
            </a>
        </nav>

        <!-- Footer / Logout -->
        <div class="sidebar-footer">
            <form method="post" action="/Identity/Account/Logout">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="/" />
                <button type="submit" class="sidebar-logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Log Out
                </button>
            </form>
        </div>

    </aside>

    <!-- ── Sidebar (mobile offcanvas) ── -->
    <div class="offcanvas offcanvas-start lgu-offcanvas" tabindex="-1" id="sidebarOffcanvas">
        <div class="offcanvas-header border-0 pb-0">
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">

            <!-- Logo -->
            <div class="sidebar-logo">
                <a class="sidebar-logo-mark" href="/LGU">
                    <img src="~/images/Logo-VoxAngelos.png" alt="Vox Angelos" class="sidebar-logo-img" />
                </a>
            </div>

            <!-- Department badge -->
            <div class="sidebar-dept">
                <div class="sidebar-dept-label">Department</div>
                <div class="sidebar-dept-name">@departmentName</div>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">
                <div class="sidebar-nav-label">Menu</div>

                <a asp-page="/LGU/Index"
                       class="sidebar-link @(IsActive("/LGU/Index") ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z" />
                        <path d="M9 21V12h6v9" />
                    </svg>
                    View Concerns
                </a>

                <a asp-page="/LGU/Leaderboard"
                       class="sidebar-link @(IsActive("/LGU/Leaderboard") ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 20V10M12 20V4M6 20v-6" />
                    </svg>
                    View Leaderboard
                </a>

                <a asp-page="/LGU/Heatmap"
                       class="sidebar-link @(IsActive("/LGU/Heatmap") ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="10" r="3" />
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                    </svg>
                    View Heatmap
                </a>
            </nav>

            <!-- Footer / Logout -->
            <div class="sidebar-footer">
                <form method="post" action="/Identity/Account/Logout">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="/" />
                    <button type="submit" class="sidebar-logout">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                            <polyline points="16 17 21 12 16 7" />
                            <line x1="21" y1="12" x2="9" y2="12" />
                        </svg>
                        Log Out
                    </button>
                </form>
            </div>

        </div>
    </div>


    <!-- ── Main ── -->
    <div class="lgu-main">

        <!-- Top bar -->
        <header class="lgu-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="burger-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                </button>
                <div class="lgu-topbar-greeting">Hello, @departmentName</div>
            </div>
        </header>

        <!-- Page content -->
        <main class="lgu-content">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

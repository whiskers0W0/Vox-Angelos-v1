@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using VoxAngelos.Data
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

@{
    var currentUser = await UserManager.GetUserAsync(User);

    var firstName = "User";

    if (currentUser != null)
    {
        firstName = await Db.UserProfiles
            .Where(p => p.UserId == currentUser.Id)
            .Select(p => p.FirstName)
            .FirstOrDefaultAsync() ?? "User";
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Vox Angelos</title>
    <link rel="stylesheet" href="~/css/citizen-layout.css" />
    @RenderSection("Styles", required: false)
</head>

<body>

    @{
        var path = Context.Request.Path.Value?.ToLower() ?? "";
    }

    <div class="layout-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="~/assets/Logo-VoxAngelos.png" class="brand-logo">
                    <span class="brand-name">ox Angelos</span>
                </div>

                <nav class="sidebar-nav">

                    <a asp-page="/User/Profile" class="nav-item @(path == "/user/profile" ? "active" : "")">
                        <img src="~/assets/VoxAngelosLogo.png" class="sidebar-avatar" alt="Profile" />
                        <span>@firstName</span>  <!-- however you access the user's first name -->
                    </a>

                    <hr class="sidebar-divider" />

                    <a asp-page="/User/Index" class="nav-item @(path == "/user" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9,22 9,12 15,12 15,22" />
                        </svg>
                        <span>Home</span>
                    </a>
                    <a asp-page="/User/Notifications" class="nav-item @(path == "/user/notifications" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                        </svg>
                        <span>Notifications</span>
                    </a>
                    <a asp-page="/User/Create" class="nav-item @(path == "/user/create" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="16" />
                            <line x1="8" y1="12" x2="16" y2="12" />
                        </svg>
                        <span>Create</span>
                    </a>
                </nav>

                <a href="/Identity/Account/Login" class="nav-item logout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16,17 21,12 16,7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    <span>Log Out</span>
                </a>
            </aside>

            <!-- Mobile top bar -->
            <div class="mobile-topbar">
                <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div class="mobile-brand">
                    <img src="~/assets/VoxAngelosLogo.png" class="brand-v">
                        <span>ox Angelos</span>
                    </div>
                </div>

                <!-- Sidebar overlay -->
                <div class="sidebar-overlay" id="sidebarOverlay"></div>

                <!-- Page Content -->
                <main class="main-content">
                    @RenderBody()
                </main>
            </div>

            
            <script>
                    const hamburgerBtn = document.getElementById('hamburgerBtn');
                    const sidebar = document.querySelector('.sidebar');
                    const overlay = document.getElementById('sidebarOverlay');

                    hamburgerBtn.addEventListener('click', () => {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('active');
                    });

                    overlay.addEventListener('click', () => {
                        sidebar.classList.remove('open');
                        overlay.classList.remove('active');
                    });
            </script>

            @RenderSection("Scripts", required: false)
        </body>

    </html>

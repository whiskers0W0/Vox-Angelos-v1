@{

}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Vox Angelos</title>
    <link rel="stylesheet" href="~/css/admin-layout.css" />
    @RenderSection("Styles", required: false)
</head>

<body>

    @{
        var path = Context.Request.Path.Value?.ToLower() ?? "";
    }

    <div class="layout-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="~/assets/VoxAngelosLogo.png" class="brand-logo">
                    <span class="brand-name">ox Angelos</span>
                </div>

                <nav class="sidebar-nav">

                    <a asp-page="/Admin/Index" class="nav-item @(path == "/admin" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" rx="1" />
                            <rect x="14" y="3" width="7" height="7" rx="1" />
                            <rect x="3" y="14" width="7" height="7" rx="1" />
                            <rect x="14" y="14" width="7" height="7" rx="1" />
                        </svg>
                        <span>Dashboard</span>
                    </a>

                    <a asp-page="/Admin/UserApplications" class="nav-item @(path == "/admin/userapplications" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <polyline points="17 11 19 13 23 9" />
                        </svg>
                        <span>User Applications</span>
                    </a>
                    <a asp-page="/Admin/OfficeManagement" class="nav-item @(path == "/admin/officemanagement" ? "active" : "")">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="4" y="11" width="16" height="10" rx="2" />
                            <path d="M12 11V7" />
                            <path d="M6 7l6-4 6 4" />
                            <path d="M8 15h.01" />
                            <path d="M12 15h.01" />
                            <path d="M16 15h.01" />
                        </svg>
                        <span>Office Management</span>
                    </a>
                 
                </nav>

                <div class="sidebar-footer">
                    <form method="post" action="/Identity/Account/Logout" class="w-100">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="/Admin/Login" />
                        <button type="submit" class="nav-item logout-btn w-100 border-0 bg-transparent text-start">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16,17 21,12 16,7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                            <span>Log Out</span>
                        </button>
                    </form>
                    </div>
            </aside>

            <!-- Mobile top bar -->
            <div class="mobile-topbar">
                <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">
                    <span></span><span></span><span></span>
                </button>
                <div class="mobile-brand">
                    <img src="~/assets/VoxAngelosLogo.png" class="brand-v">
                        <span>ox Angelos</span>
                    </div>
                </div>

                <!-- Sidebar overlay -->
                <div class="sidebar-overlay" id="sidebarOverlay"></div>

                <!-- Page Content -->
                <main class="main-content">
                    @RenderBody()
                </main>
            </div>

            
            <script>
                    const hamburgerBtn = document.getElementById('hamburgerBtn');
                    const sidebar = document.querySelector('.sidebar');
                    const overlay = document.getElementById('sidebarOverlay');

                    hamburgerBtn.addEventListener('click', () => {
                        sidebar.classList.toggle('open');
                        overlay.classList.toggle('active');
                    });

                    overlay.addEventListener('click', () => {
                        sidebar.classList.remove('open');
                        overlay.classList.remove('active');
                    });
            </script>

            @RenderSection("Scripts", required: false)
        </body>

    </html>
